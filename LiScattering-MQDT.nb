Cell[BoxData[
 RowBox[{
  RowBox[{"\[Eta]lowE", "[", 
   RowBox[{"\[Epsilon]_", ",", "L_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{"-", "1"}], ")"}], 
     RowBox[{"L", "+", "1"}]], 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{
       RowBox[{"abar", "[", "L", "]"}], 
       SqrtBox["\[Epsilon]"]}], ")"}], 
     RowBox[{
      RowBox[{"2", "L"}], "+", "1"}]]}], "-", 
   RowBox[{
    FractionBox[
     RowBox[{"3", "\[Pi]", " ", 
      RowBox[{"Gamma", "[", 
       RowBox[{"L", "-", 
        FractionBox["3", "2"]}], "]"}]}], 
     RowBox[{"32", " ", 
      RowBox[{"Gamma", "[", 
       RowBox[{"L", "+", 
        FractionBox["7", "2"]}], "]"}]}]], 
    SuperscriptBox["\[Epsilon]", "2"]}]}]}]], "Input",

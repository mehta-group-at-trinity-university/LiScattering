Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"\[Eta]table", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"\[Epsilon]table", "[", 
        RowBox[{"[", "i", "]"}], "]"}], ",", 
       RowBox[{"ArcTan", "[", 
        RowBox[{"lowEparameters", "[", 
         RowBox[{"[", 
          RowBox[{"i", ",", "1"}], "]"}], "]"}], "]"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", "NE"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Eta]tablenew", "=", "\[Eta]table"}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"For", "[", 
   RowBox[{
    RowBox[{"i", "=", "1"}], ",", 
    RowBox[{"i", "<", 
     RowBox[{"Length", "[", "\[Eta]table", "]"}]}], ",", 
    RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", 
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"\[Eta]table", "[", 
          RowBox[{"[", 
           RowBox[{
            RowBox[{"i", "+", "1"}], ",", "2"}], "]"}], "]"}], "-", 
         RowBox[{"\[Eta]table", "[", 
          RowBox[{"[", 
           RowBox[{"i", ",", "2"}], "]"}], "]"}]}], ">", "1.2"}], ")"}], ",", 
      
      RowBox[{
       RowBox[{"Print", "[", "i", "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"\[Eta]tablenew", "[", 
         RowBox[{"[", 
          RowBox[{
           RowBox[{
            RowBox[{"i", "+", "1"}], ";;", "NE"}], ",", "2"}], "]"}], "]"}], 
        "=", 
        RowBox[{
         RowBox[{"\[Eta]tablenew", "[", 
          RowBox[{"[", 
           RowBox[{
            RowBox[{
             RowBox[{"i", "+", "1"}], ";;", "NE"}], ",", "2"}], "]"}], "]"}], 
         "-", "\[Pi]"}]}]}], ",", 
      RowBox[{
       RowBox[{"\[Eta]tablenew", "[", 
        RowBox[{"[", 
         RowBox[{
          RowBox[{
           RowBox[{"i", "+", "1"}], ";;", "NE"}], ",", "2"}], "]"}], "]"}], 
       "=", 
       RowBox[{"\[Eta]tablenew", "[", 
        RowBox[{"[", 
         RowBox[{
          RowBox[{
           RowBox[{"i", "+", "1"}], ";;", "NE"}], ",", "2"}], "]"}], 
        "]"}]}]}], "\[IndentingNewLine]", "]"}]}], "]"}], ";"}], "\n", 
 RowBox[{"peta1", "=", 
  RowBox[{"ListPlot", "[", "\[Eta]tablenew", "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"ListPlot", "[", "\[Eta]table", "]"}], "*)"}]}]}], "Input",

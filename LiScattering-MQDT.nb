            RowBox[{"2", "L"}], "+", "3"}], ")"}], 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"2", "L"}], "-", "1"}], ")"}]}]]}], "+", 
       RowBox[{
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{"-", "1"}], ")"}], 
         RowBox[{"L", "+", "1"}]], 
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{
           RowBox[{"abar", "[", "ltest", "]"}], " ", 
           SqrtBox["\[Epsilon]"]}], ")"}], 
         RowBox[{
          RowBox[{"4", "L"}], "+", "2"}]]}]}], "/.", 
      RowBox[{"L", "\[Rule]", "ltest"}]}], ",", 

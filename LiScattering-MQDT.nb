Cell[TextData[{
 "The collision energy relative to channel ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "125de36c-e2ef-47f8-81e4-c40e50d4e986"],
 " at field ",
 Cell[BoxData[
  FormBox["B", TraditionalForm]],ExpressionUUID->
  "ce1b44cb-c39f-4b15-a773-fcdadf829517"],
 ":"
}], "Text",
 CellChangeTimes->{{3.822831025179227*^9, 
  3.822831048487068*^9}},ExpressionUUID->"a9890469-79ad-4486-9b0c-\
fd7efcd6f92b"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[ScriptCapitalE]", "[", 
   RowBox[{"n_", ",", "Ecol_", ",", "B_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{
    RowBox[{"EthA", "[", 
     RowBox[{"[", "1", "]"}], "]"}], "[", "B", "]"}], "+", "Ecol", "-", 
   RowBox[{
    RowBox[{"EthA", "[", 
     RowBox[{"[", "n", "]"}], "]"}], "[", "B", "]"}]}]}]], "Input",
 CellChangeTimes->{{3.801844962267432*^9, 3.8018449760431843`*^9}, {
  3.801845098386581*^9, 3.801845109901338*^9}, {3.801847189475421*^9, 
  3.801847193828607*^9}, {3.801917735621211*^9, 3.80191774166356*^9}, {
  3.80194934876516*^9, 3.801949391933261*^9}, {3.822876172351631*^9, 
  3.822876176902032*^9}, {3.8228766852256193`*^9, 3.822876694778852*^9}},
 CellLabel->
  "In[615]:=",ExpressionUUID->"363294a9-fc82-4345-bf47-ac735a56b92d"],

Cell[TextData[{
 "To be clear, the above expression assumes that the zero of the energy is at \
channel ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "b7ac779d-5d43-477e-ba73-5389a6ad4118"],
 ", but the collision energy is measured with respect to the lowest channel."
}], "Text",
 CellChangeTimes->{{3.8228769709930973`*^9, 3.822877020329938*^9}, {
  3.822878243208515*^9, 
  3.822878245732538*^9}},ExpressionUUID->"17cb2276-8e02-4c95-b83d-\
4f1d9b14f2dc"],


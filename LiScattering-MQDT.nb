           RowBox[{"{", 
            RowBox[{"f1", ",", " ", 
             RowBox[{"-", "m1"}]}], "}"}]}], "]"}], "*", 
         RowBox[{"ThreeJSymbol", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"s2", ",", "ms2"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"i2", ",", "mi2"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"f2", ",", 
             RowBox[{"-", "m2"}]}], "}"}]}], "]"}], "*", 
         RowBox[{"ThreeJSymbol", "[", 
          RowBox[{
           RowBox[{"{", 

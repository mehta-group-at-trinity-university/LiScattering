Cell[CellGroupData[{

Cell["Threshold expressions", "Subsection",
 CellChangeTimes->{{3.815621903790485*^9, 
  3.815621907972498*^9}},ExpressionUUID->"fdbc9c1e-927a-4991-b5c0-\
69e59a902a66"],

Cell[TextData[{
 "At threshold, one should in principle be able to use the approximate \
threshold expressions for the MQDT parameters.  For elastic scattering, the \
only parameter that needs to be evaluated at nonzero energies is ",
 Cell[BoxData[
  FormBox[
   RowBox[{"cot", " ", "\[Gamma]"}], TraditionalForm]],ExpressionUUID->
  "06eec9f9-7489-4ae1-acce-f164be0f99e9"],
 ".  We have at threshold:"
}], "Text",
 CellChangeTimes->{{3.8156219093483353`*^9, 
  3.815621988767931*^9}},ExpressionUUID->"ad67870c-07dd-4158-92bb-\
b059fec1b59d"],

Cell[TextData[{
 "Let\[CloseCurlyQuote]s take a look at the threshold behavior of ",
 Cell[BoxData[
  FormBox["K", TraditionalForm]],ExpressionUUID->
  "d07283d4-a550-4eef-8cd3-eae55b7c05ec"],
 " and of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"tan", " ", "\[Eta]"}], TraditionalForm]],ExpressionUUID->
  "a8c5eafc-7975-4756-b5cf-040df21206ad"],
 ".  First ",
 Cell[BoxData[
  FormBox["K", TraditionalForm]],ExpressionUUID->
  "00150542-5ccb-4869-9d2a-db2ddf39b56d"],
 ", at threshold"
}], "Text",
 CellChangeTimes->{{3.815350438353986*^9, 3.815350444191917*^9}, {
  3.8153504878410883`*^9, 3.815350509446909*^9}, {3.8153505652236147`*^9, 
  3.8153505760906963`*^9}, {3.8153506140261173`*^9, 
  3.815350615428871*^9}},ExpressionUUID->"e62b2803-eff5-4b72-b8a2-\
fa3f652c4a48"],

Cell[BoxData[
 FormBox[
  RowBox[{"K", "=", 
   RowBox[{
    RowBox[{
     SuperscriptBox["\[ScriptCapitalA]", 
      RowBox[{"1", "/", "2"}]], " ", 
     FractionBox["1", 
      RowBox[{
       SuperscriptBox[
        OverscriptBox["K", "~"], 
        RowBox[{"-", "1"}]], "+", 
       RowBox[{"\[ScriptCapitalG]", "(", "\[Epsilon]", ")"}]}]], 
     SuperscriptBox["\[ScriptCapitalA]", 
      RowBox[{"1", "/", "2"}]]}], "\[Rule]", " ", 
    RowBox[{
     RowBox[{
      OverscriptBox["a", "_"], 
      SqrtBox["\[Epsilon]"], 
      FractionBox[
       OverscriptBox["K", "~"], 
       RowBox[{"1", "+", 
        RowBox[{
         OverscriptBox["K", "~"], 
         RowBox[{"\[ScriptCapitalG]", "(", "\[Epsilon]", ")"}]}]}]]}], 
     "\[Rule]", 
     RowBox[{
      OverscriptBox["a", "_"], 
      SqrtBox["\[Epsilon]"], 
      OverscriptBox["K", "~"], " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"1", "-", 
         RowBox[{
          OverscriptBox["K", "~"], "\[ScriptCapitalG]"}], "+"}], "..."}], 
       ")"}]}]}]}]}], TraditionalForm]], "EquationNumbered",
 CellChangeTimes->{{3.815350438353986*^9, 3.815350444191917*^9}, {
  3.8153504878410883`*^9, 3.8153506209599657`*^9}, {3.815350652912491*^9, 

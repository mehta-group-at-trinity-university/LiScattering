       "i_", ",", "mi_", ",", "s1_", ",", "i1_", ",", "s2_", ",", "i2_"}], 
      "]"}], ":=", " ", 
     RowBox[{
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"-", "1"}], ")"}], 
       RowBox[{
        RowBox[{"2", "i2"}], "-", 
        RowBox[{"2", "s1"}], "-", "m1", "-", "m2", "-", "ms", "-", "mi"}]], 
      RowBox[{"\[Sqrt]", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"2", "f1"}], "+", "1"}], ")"}], 
         RowBox[{"(", 

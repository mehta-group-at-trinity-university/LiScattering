      "f1_", ",", "m1_", ",", "f1p_", ",", "m1p_", ",", "f2_", ",", "m2_", 
       ",", "f2p_", ",", "m2p_", ",", "s1_", ",", "i1_", ",", "s2_", ",", 
       "i2_", ",", "S_"}], "]"}], ":=", " ", 
     RowBox[{"Sum", "[", 
      RowBox[{
       RowBox[{"Sum", "[", 
        RowBox[{
         RowBox[{

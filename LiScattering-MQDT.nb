Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"QuantumDefectParameters", "[", 
    RowBox[{
    "\[Phi]_", ",", "l_", ",", "rx_", ",", "rfinal_", ",", "\[Epsilon]_"}], 
    "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "fs", ",", "fsp", ",", "gs", ",", "gsp", ",", "\[ScriptCapitalA]", ",", 

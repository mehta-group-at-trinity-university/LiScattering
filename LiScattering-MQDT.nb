Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{"tan", " ", "\[Eta]"}], "\[Rule]", " ", 
   RowBox[{"\[Eta]", "\[Rule]", " ", 
    RowBox[{
     RowBox[{"-", 
      OverscriptBox["a", "_"]}], 
     SqrtBox["\[Epsilon]"]}]}]}], TraditionalForm]], "EquationNumbered",

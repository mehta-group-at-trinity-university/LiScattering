        RowBox[{"{", 
         RowBox[{"mi2", ",", 
          RowBox[{"-", "i2"}], ",", "i2"}], "}"}]}], "]"}]}]}], ";"}], "*)"}],
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
     RowBox[{"ProjectionMatrixElement", "[", 

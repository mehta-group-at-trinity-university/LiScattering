  3.8153510422302*^9}},ExpressionUUID->"9cdc0841-71fe-499c-91a4-b91e658a6043"],

Cell[TextData[{
 "The final expression assumes that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["K", "~"], 
    RowBox[{"\[ScriptCapitalG]", "(", "\[Epsilon]", ")"}], 
    RowBox[{"<<", "1", " "}]}], TraditionalForm]],ExpressionUUID->
  "bf5eb8b9-aed6-4518-ae6c-de6ee773a9a1"],
 "as ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Epsilon]", "\[Rule]", "0"}], TraditionalForm]],ExpressionUUID->
  "906009ba-d900-41a0-ab95-16d446b1e6f2"],
 ".  Meanwhile"
}], "Text",
 CellChangeTimes->{{3.815350740947603*^9, 3.815350748740459*^9}, {

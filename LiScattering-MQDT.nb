Cell[CellGroupData[{

Cell[TextData[{
 "\[LineSeparator]",
 StyleBox["Create an interpolated function to evaluate this fast and convert \
to van der Waals units", "Subsection"]
}], "Subsubsection",
 CellChangeTimes->{{3.799769560539075*^9, 3.799769568527149*^9}, 
   3.801745197629498*^9, {3.801751801960693*^9, 
   3.801751810264036*^9}},ExpressionUUID->"5f758f72-f149-443d-a42c-\
73d88b2b4f6e"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"Rmax", "=", "300"}], ";"}], " ", 
  RowBox[{"(*", "bohr", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Rmin", "=", "1.0"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"NR", " ", "=", "500"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"dR", "=", 
   FractionBox[
    RowBox[{"(", 
     RowBox[{"Rmax", "-", "Rmin"}], ")"}], 
    RowBox[{"(", 
     RowBox[{"NR", "-", "1"}], ")"}]]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"RGrid", " ", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"Rmin", "+", 
      RowBox[{
       SuperscriptBox[
        RowBox[{"(", 
         FractionBox[
          RowBox[{"(", 
           RowBox[{"iR", "-", "1"}], ")"}], 
          RowBox[{"(", 
           RowBox[{"NR", "-", "1"}], ")"}]], ")"}], "3"], 
       RowBox[{"(", 
        RowBox[{"Rmax", "-", "Rmin"}], ")"}]}]}], ",", 
     RowBox[{"{", 
      RowBox[{"iR", ",", "1", ",", "NR"}], "}"}]}], "]"}]}], ";"}]}], "Input",\

 InitializationCell->True,
 CellChangeTimes->{{3.799191626153859*^9, 3.7991918342807302`*^9}, {
   3.799191898152261*^9, 3.799191926342634*^9}, 3.799191959353692*^9, {
   3.799419120558796*^9, 3.7994191226516323`*^9}, {3.799419207175235*^9, 
   3.7994192074589252`*^9}, {3.799433891617839*^9, 3.7994339000283403`*^9}, {

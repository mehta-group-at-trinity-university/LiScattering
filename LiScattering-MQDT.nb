Cell[TextData[{
 "Seems like this agrees in the threshold limit, but the threshold limit of \
",
 Cell[BoxData[
  FormBox["\[Gamma]", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "7eb3b6a5-c970-4095-a82e-624f4c77f0d3"],
 " seems to not be particularly important for ultracold scattering since ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Kappa]", "=", 
    SqrtBox[
     RowBox[{"-", "E"}]]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "77b10246-9192-469f-982e-ab1bf1b42130"],
 " is typically large for closed channels the hyperfine splitting is much \
bigger than 1 in van der Waals units."
}], "Text",
 CellChangeTimes->{{3.822874317031416*^9, 3.822874340131508*^9}, {
  3.822874433711997*^9, 3.822874481376189*^9}, {3.8228749363547497`*^9, 
  3.822874959974852*^9}, {3.8228753911078176`*^9, 3.82287541496844*^9}, {
  3.822878198293911*^9, 
  3.822878199211441*^9}},ExpressionUUID->"d092c7a3-c3ab-4fc9-a862-\
d86adfd69a2a"],


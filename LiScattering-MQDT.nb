Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    RowBox[{
     TemplateBox[{
       RowBox[{"{", 
         RowBox[{
           RowBox[{"\[Alpha]", "'"}], 
           RowBox[{"\[Beta]", "'"}]}], "}"}]},
      "Bra"], 
     SuperscriptBox[
      SubscriptBox["H", "1"], "HZ"]}], "+", 
    RowBox[{
     SuperscriptBox[
      SubscriptBox["H", "2"], "HZ"], 
     TemplateBox[{
       RowBox[{"{", "\[Alpha]\[Beta]", "}"}]},
      "Ket"]}]}], "=", 
   RowBox[{
    FractionBox["1", 
     SqrtBox[
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "+", 
         SubscriptBox["\[Delta]", 
          RowBox[{"\[Alpha]", "\[LineSeparator]"}]]}], ")"}], 
       RowBox[{"(", 
        RowBox[{"1", "+", 
         SubscriptBox["\[Delta]", 
          RowBox[{
           RowBox[{"\[Alpha]", "'"}], 
           RowBox[{"\[Beta]", "'"}]}]]}], ")"}]}]]], "[", 
    RowBox[{
     RowBox[{
      TemplateBox[{
        RowBox[{"\[Alpha]", "'"}]},
       "Bra"], 

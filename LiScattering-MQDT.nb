 RowBox[{
  RowBox[{"abar", "[", "L_", "]"}], ":=", 
  SuperscriptBox[
   RowBox[{"(", 
    FractionBox[
     RowBox[{"\[Pi]", " ", 
      SuperscriptBox["2", 
       RowBox[{"-", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"2", "L"}], "+", 
          RowBox[{"3", "/", "2"}]}], ")"}]}]]}], 
     RowBox[{
      RowBox[{"Gamma", "[", 
       RowBox[{

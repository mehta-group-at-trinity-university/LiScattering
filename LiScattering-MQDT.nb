Cell[CellGroupData[{

Cell["\[LineSeparator]Find the singlet/triplet quantum defects", "Subsection",
 CellChangeTimes->{{3.801759025397852*^9, 3.8017590418780603`*^9}, 
   3.801786452407947*^9},ExpressionUUID->"4d86dfe5-a67a-42a0-8123-\
c2604f627597"],

Cell[BoxData[
 RowBox[{
  RowBox[{"CalcY", "[", 
   RowBox[{
   "\[CapitalEpsilon]_", ",", "l_", ",", "rmin_", ",", "rmax_", ",", "\[Mu]_",
     ",", "r0_", ",", "U_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"Y", ",", "u", ",", "up", ",", "rp", ",", "r"}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"u", "=", 
      RowBox[{"NDSolveValue", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{
             FractionBox[
              RowBox[{"-", "1"}], 
              RowBox[{"2", " ", "\[Mu]"}]], 
             RowBox[{
              RowBox[{"u", "''"}], "[", "r", "]"}]}], "+", " ", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{
               RowBox[{"U", "[", "r", "]"}], "+", 
               FractionBox[
                RowBox[{"l", 
                 RowBox[{"(", 
                  RowBox[{"l", "+", "1"}], ")"}]}], 
                RowBox[{"2", " ", "\[Mu]", " ", 
                 SuperscriptBox["r", "2"]}]]}], ")"}], "*", 
             RowBox[{"u", "[", "r", "]"}]}]}], "\[Equal]", 
           RowBox[{"\[CapitalEpsilon]", " ", 
            RowBox[{"u", "[", "r", "]"}]}]}], ",", 
          RowBox[{
           RowBox[{"u", "[", "rmin", "]"}], "\[Equal]", "0"}], ",", 
          RowBox[{
           RowBox[{
            RowBox[{"u", "'"}], "[", "rmin", "]"}], "\[Equal]", 
           SuperscriptBox["10", 
            RowBox[{"-", "10"}]]}]}], "}"}], ",", "u", ",", 
        RowBox[{"{", 
         RowBox[{"r", ",", "rmin", ",", "rmax"}], "}"}], ",", 
        RowBox[{"AccuracyGoal", "\[Rule]", "20"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"up", "[", "r_", "]"}], " ", "=", " ", 
      RowBox[{
       RowBox[{"D", "[", 
        RowBox[{
         RowBox[{"u", "[", "rp", "]"}], ",", "rp"}], "]"}], "/.", 
       RowBox[{"rp", "\[Rule]", "r"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Y", " ", "=", " ", 
      RowBox[{
       FractionBox[
        RowBox[{"up", "[", "r", "]"}], 
        RowBox[{"u", "[", "r", "]"}]], "/.", 
       RowBox[{"r", "\[Rule]", "r0"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Return", "[", 
      RowBox[{"{", 
       RowBox[{"Y", ",", "u"}], "}"}], "]"}]}]}], "\[IndentingNewLine]", 
   "]"}]}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{
  3.801759446387066*^9, {3.801759542210575*^9, 3.8017595851566877`*^9}, {
   3.8017608672510242`*^9, 3.801760890826047*^9}, 3.8017614361710453`*^9, {
   3.8017618092272243`*^9, 3.8017618458744802`*^9}, 3.801781198790978*^9, {
   3.801784316026011*^9, 3.801784318293621*^9}, {3.8017845599910507`*^9, 
   3.801784596580311*^9}, {3.8017847404437027`*^9, 3.801784768214175*^9}, {
   3.801784853072204*^9, 3.801784927436664*^9}, {3.801785013286594*^9, 
   3.801785049744659*^9}, {3.801787593774802*^9, 3.801787598765657*^9}, {
   3.80178907183246*^9, 3.801789076940186*^9}, {3.801790231698493*^9, 
   3.801790233377942*^9}, {3.8017907806094027`*^9, 3.8017908337041483`*^9}, {

          RowBox[{"ii", ",", "1", ",", "Nopen"}], "}"}]}], "]"}], "]"}]}], 
     ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"ds", "[", 
       RowBox[{"\[CapitalEpsilon]", ",", "r"}], "]"}], "=", 

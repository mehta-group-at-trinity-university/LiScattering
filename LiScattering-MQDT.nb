Cell[BoxData[{
 RowBox[{
  RowBox[{"TripletMLRHBdat", " ", "=", " ", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"RGrid", "[", 
        RowBox[{"[", "i", "]"}], "]"}], ",", 
       RowBox[{"invcminHartree", "*", 
        RowBox[{"TripletMLR", "[", 
         RowBox[{
          RowBox[{"RGrid", "[", 
           RowBox[{"[", "i", "]"}], "]"}], "BohrinAngstrom"}], "]"}]}]}], 
      "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", "NR"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"TripletHBMLR", "=", 
   RowBox[{"Interpolation", "[", 
    RowBox[{"TripletMLRHBdat", ",", 
     RowBox[{"Method", "\[Rule]", "\"\<Hermite\>\""}], ",", 
     RowBox[{"InterpolationOrder", "\[Rule]", "5"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"SingletMLRHBdat", " ", "=", " ", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"RGrid", "[", 
        RowBox[{"[", "i", "]"}], "]"}], ",", 
       RowBox[{"invcminHartree", "*", 
        RowBox[{"SingletMLR", "[", 
         RowBox[{
          RowBox[{"RGrid", "[", 
           RowBox[{"[", "i", "]"}], "]"}], "BohrinAngstrom"}], "]"}]}]}], 
      "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", "NR"}], "}"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"SingletHBMLR", "=", 
   RowBox[{"Interpolation", "[", 
    RowBox[{"SingletMLRHBdat", ",", 
     RowBox[{"Method", "\[Rule]", "\"\<Hermite\>\""}], ",", 
     RowBox[{"InterpolationOrder", "\[Rule]", "5"}]}], "]"}]}], 
  ";"}]}], "Input",

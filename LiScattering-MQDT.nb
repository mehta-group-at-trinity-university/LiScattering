  3.8153509007014303`*^9}},ExpressionUUID->"65c17b3d-61f0-4c22-921e-\
36bca80a19ad"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{"a", "(", 
    RowBox[{"\[Epsilon]", ",", "B"}], ")"}], "=", 
   RowBox[{
    RowBox[{
     FractionBox[
      RowBox[{"-", "1"}], 
      SqrtBox["\[Epsilon]"]], " ", 
     FractionBox[
      RowBox[{
       RowBox[{
        RowBox[{"-", 
         OverscriptBox["a", "_"]}], 
        SqrtBox["\[Epsilon]"]}], "+", 
       RowBox[{
        OverscriptBox["a", "_"], 
        SqrtBox["\[Epsilon]"], 
        OverscriptBox["K", "~"]}]}], 
      RowBox[{"1", "+", 
       RowBox[{
        OverscriptBox["a", "_"], 
        SqrtBox["\[Epsilon]"], 
        OverscriptBox["a", "_"], 
        SqrtBox["\[Epsilon]"], 
        OverscriptBox["K", "~"]}]}]]}], "=", " ", 
    FractionBox[
     RowBox[{
      OverscriptBox["a", "_"], "  ", 
      RowBox[{"(", 
       RowBox[{"1", "-", 
        OverscriptBox["K", "~"]}], ")"}]}], 
     RowBox[{"1", "+", 
      RowBox[{
       SuperscriptBox[
        OverscriptBox["a", "_"], "2"], "\[Epsilon]", 
       OverscriptBox["K", "~"]}]}]]}]}], TraditionalForm]], "EquationNumbered",\

 CellChangeTimes->{{3.8153511492100077`*^9, 
  3.8153512988947277`*^9}},ExpressionUUID->"1d41052f-a2ae-4f5d-8341-\

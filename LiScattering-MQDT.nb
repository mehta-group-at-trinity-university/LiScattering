Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumDefect", "[", 
   RowBox[{
   "\[Phi]_", ",", "l_", ",", "rmin_", ",", "rx_", ",", "r0_", ",", "rmax_", 
    ",", "U_", ",", "\[Epsilon]_", ",", "\[Mu]_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "u", ",", "\[Alpha]", ",", "rp", ",", "\[Alpha]rule", ",", "\[Alpha]fun",
       ",", "phaseint", ",", "f0", ",", "g0", ",", "f0p", ",", "g0p", ",", 
      "\[Alpha]p", ",", "\[Chi]m", ",", "\[Chi]mp", ",", "logder", ",", 
      "Ksr"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"\[Alpha]rule", "=", 
      RowBox[{"NDSolve", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"\[Alpha]", "''"}], "[", "r", "]"}], "+", 
            RowBox[{
             RowBox[{"ksqr", "[", 
              RowBox[{"\[Epsilon]", ",", "l", ",", "r"}], "]"}], 
             RowBox[{"\[Alpha]", "[", "r", "]"}]}], "-", 
            FractionBox["1", 
             SuperscriptBox[
              RowBox[{"\[Alpha]", "[", "r", "]"}], "3"]]}], "\[Equal]", "0"}],
           ",", 
          RowBox[{
           RowBox[{"\[Alpha]", "[", "rx", "]"}], "\[Equal]", 
           RowBox[{"BC1", "[", 
            RowBox[{"\[Epsilon]", ",", "l", ",", "rx"}], "]"}]}], ",", 
          RowBox[{
           RowBox[{
            RowBox[{"\[Alpha]", "'"}], "[", "rx", "]"}], "\[Equal]", 
           RowBox[{"BC2", "[", 
            RowBox[{"\[Epsilon]", ",", "l", ",", "rx"}], "]"}]}]}], "}"}], 
        ",", "\[Alpha]", ",", 
        RowBox[{"{", 
         RowBox[{"r", ",", "rx", ",", "rmax"}], "}"}], ",", 
        RowBox[{"AccuracyGoal", "\[Rule]", "20"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"\[Alpha]fun", "=", 
      RowBox[{"\[Alpha]", "/.", 
       RowBox[{"\[Alpha]rule", "[", 
        RowBox[{"[", "1", "]"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"phaseint", "=", 
      RowBox[{"NIntegrate", "[", 
       RowBox[{
        SuperscriptBox[
         RowBox[{"\[Alpha]fun", "[", "rp", "]"}], 
         RowBox[{"-", "2"}]], ",", 
        RowBox[{"{", 
         RowBox[{"rp", ",", "rx", ",", "r0"}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"\[Alpha]p", "=", 
      RowBox[{
       RowBox[{"D", "[", 
        RowBox[{
         RowBox[{"\[Alpha]fun", "[", "rp", "]"}], ",", "rp"}], "]"}], "/.", 
       RowBox[{"rp", "\[Rule]", "r0"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"g0", "=", 
      RowBox[{
       FractionBox[
        RowBox[{"-", 
         RowBox[{"\[Alpha]fun", "[", "r0", "]"}]}], 
        SqrtBox["\[Pi]"]], 
       RowBox[{"Cos", "[", 
        RowBox[{"\[Phi]", "+", "phaseint"}], "]"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"g0p", "=", 
      RowBox[{
       RowBox[{
        FractionBox["\[Alpha]p", 
         RowBox[{"\[Alpha]fun", "[", "r0", "]"}]], "g0"}], "+", 
       RowBox[{
        FractionBox["1", 
         SuperscriptBox[
          RowBox[{"\[Alpha]fun", "[", "r0", "]"}], "2"]], "f0"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"f0", "=", 
      RowBox[{
       FractionBox[
        RowBox[{"\[Alpha]fun", "[", "r0", "]"}], 
        SqrtBox["\[Pi]"]], 
       RowBox[{"Sin", "[", 
        RowBox[{"\[Phi]", "+", "phaseint"}], "]"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"f0p", "=", 
      RowBox[{
       RowBox[{
        FractionBox["\[Alpha]p", 
         RowBox[{"\[Alpha]fun", "[", "r0", "]"}]], "f0"}], "-", 
       RowBox[{
        FractionBox["1", 
         SuperscriptBox[
          RowBox[{"\[Alpha]fun", "[", "r0", "]"}], "2"]], "g0"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"logder", ",", "u"}], "}"}], "=", 
      RowBox[{"CalcY", "[", 
       RowBox[{
       "\[Epsilon]", ",", "l", ",", "rmin", ",", "rmax", ",", "\[Mu]", ",", 
        "r0", ",", "U"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Ksr", "=", 
      FractionBox[
       RowBox[{
        RowBox[{"logder", " ", "f0"}], "-", "f0p"}], 
       RowBox[{
        RowBox[{"logder", " ", "g0"}], "-", "g0p"}]]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{"Ksr", ",", 
       RowBox[{
        RowBox[{"ArcTan", "[", "Ksr", "]"}], "/", "\[Pi]"}]}], "}"}]}]}], 
   "\[IndentingNewLine]", "]"}]}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.801759046861553*^9, 3.801759052380109*^9}, {

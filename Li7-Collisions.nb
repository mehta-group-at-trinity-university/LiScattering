    RowBox[{"Sqrt", "[", 
     FractionBox["k", "\[Pi]"], "]"}], " ", "r", " ", 
    RowBox[{"SphericalBesselJ", "[", 
     RowBox[{"l", ",", 
      RowBox[{"k", " ", "r"}]}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"g", "[", 
    RowBox[{"l_", ",", "k_", ",", "r_"}], "]"}], ":=", " ", 
   RowBox[{
    RowBox[{"Sqrt", "[", 
     FractionBox["k", "\[Pi]"], "]"}], " ", "r", " ", 
    RowBox[{"SphericalBesselY", "[", 
     RowBox[{"l", ",", 
      RowBox[{"k", " ", "r"}]}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"dfdr", "[", 
     RowBox[{"l_", ",", "k_", ",", "r_"}], "]"}], ":=", 
    RowBox[{
     RowBox[{"D", "[", 
      RowBox[{
       RowBox[{"f", "[", 
        RowBox[{"l", ",", "k", ",", "rp"}], "]"}], ",", "rp"}], "]"}], "/.", 
     RowBox[{"rp", "\[Rule]", "r"}]}]}], ";"}], " "}], "\[IndentingNewLine]", 

 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"dgdr", "[", 
     RowBox[{"l_", ",", "k_", ",", "r_"}], "]"}], ":=", 
    RowBox[{
     RowBox[{"D", "[", 
      RowBox[{
       RowBox[{"g", "[", 
        RowBox[{"l", ",", "k", ",", "rp"}], "]"}], ",", "rp"}], "]"}], "/.", 
     " ", 
     RowBox[{"rp", "\[Rule]", "r"}]}]}], ";"}], " "}]}], "Input",
 CellChangeTimes->{{3.801181252424097*^9, 3.8011812660139647`*^9}, {
  3.801245959875268*^9, 3.801245996141616*^9}, {3.801246073020248*^9, 

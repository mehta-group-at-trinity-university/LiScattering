Cell[BoxData[
 RowBox[{
  RowBox[{"CalcQuantumDefect", "[", 
   RowBox[{
   "\[CapitalEpsilon]_", ",", "l_", ",", "rmin_", ",", "rmax_", ",", "r0_", ",",
     "rx_", ",", "rf_", ",", "r_", ",", "nr_", ",", "U_", ",", "\[Phi]_"}], 
   "]"}], ":=", " ", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "phaseint", ",", "\[Alpha]p", ",", "rp", ",", "\[Alpha]fun", ",", 
      "\[Alpha]", ",", "f0", ",", "f0p", ",", "g0", ",", "g0p", ",", "u", ",",
       "up", ",", "Y", ",", "Ksr", ",", "mu"}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"\[Alpha]fun", " ", "=", " ", 
      RowBox[{"NDSolveValue", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"\[Alpha]", "''"}], "[", "r", "]"}], " ", "+", " ", 
            RowBox[{
             RowBox[{"ksqr", "[", 
              RowBox[{"\[CapitalEpsilon]", ",", "l", ",", "r"}], "]"}], 
             RowBox[{"\[Alpha]", "[", "r", "]"}]}], " ", "-", 
            FractionBox["1", 
             SuperscriptBox[
              RowBox[{"\[Alpha]", "[", "r", "]"}], "3"]]}], "\[Equal]", " ", 
           "0"}], ",", " ", 
          RowBox[{
           RowBox[{"\[Alpha]", "[", "rx", "]"}], " ", "\[Equal]", " ", 
           RowBox[{"BC1", "[", 
            RowBox[{"\[CapitalEpsilon]", ",", "l", ",", "r", ",", "rx"}], 
            "]"}]}], ",", 
          RowBox[{
           RowBox[{
            RowBox[{"\[Alpha]", "'"}], "[", "rx", "]"}], " ", "\[Equal]", " ", 
           RowBox[{"BC2", "[", 
            RowBox[{"\[CapitalEpsilon]", ",", "l", ",", "r", ",", "rx"}], 
            "]"}]}]}], "}"}], ",", "\[Alpha]", ",", 
        RowBox[{"{", 
         RowBox[{"r", ",", "rx", ",", "rf"}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"phaseint", "=", 
      RowBox[{"NIntegrate", "[", 
       RowBox[{
        SuperscriptBox[
         RowBox[{"\[Alpha]fun", "[", "rp", "]"}], 
         RowBox[{"-", "2"}]], ",", 
        RowBox[{"{", 
         RowBox[{"rp", ",", "rx", ",", "r0"}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"\[Alpha]p", "=", 
      RowBox[{"\[Alpha]fun", "'"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"g0", "=", 
      RowBox[{
       RowBox[{"-", 
        RowBox[{"\[Alpha]", "[", "r0", "]"}]}], 
       RowBox[{"Cos", "[", 
        RowBox[{"\[Phi]", "+", "phaseint"}], "]"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"g0p", "=", 
      RowBox[{
       RowBox[{
        FractionBox[
         RowBox[{"\[Alpha]p", "[", "r0", "]"}], 
         RowBox[{"\[Alpha]fun", "[", "r0", "]"}]], "g0"}], "+", 
       RowBox[{
        FractionBox["1", 
         SuperscriptBox[
          RowBox[{"\[Alpha]fun", "[", "r0", "]"}], "2"]], "f0"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"f0", "=", 
      RowBox[{
       RowBox[{"\[Alpha]", "[", "r0", "]"}], 
       RowBox[{"Sin", "[", 
        RowBox[{"\[Phi]", "+", "phaseint"}], "]"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"f0p", "=", 
      RowBox[{
       RowBox[{
        FractionBox[
         RowBox[{"\[Alpha]p", "[", "r0", "]"}], 
         RowBox[{"\[Alpha]fun", "[", "r0", "]"}]], "f0"}], "-", 
       RowBox[{
        FractionBox["1", 
         SuperscriptBox[
          RowBox[{"\[Alpha]fun", "[", "r0", "]"}], "2"]], "g0"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"u", "=", 
      RowBox[{"NDSolveValue", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"-", 
             RowBox[{
              RowBox[{"u", "''"}], "[", "r", "]"}]}], "+", " ", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{
               RowBox[{"U", "[", "r", "]"}], "+", 
               FractionBox[
                RowBox[{"l", 
                 RowBox[{"(", 
                  RowBox[{"l", "+", "1"}], ")"}]}], 
                RowBox[{" ", 
                 SuperscriptBox["r", "2"]}]]}], ")"}], 
             RowBox[{"u", "[", "r", "]"}]}]}], "\[Equal]", 
           RowBox[{"\[CapitalEpsilon]", " ", 
            RowBox[{"u", "[", "r", "]"}]}]}], ",", 
          RowBox[{
           RowBox[{"u", "[", "rmin", "]"}], "\[Equal]", "0"}], ",", 
          RowBox[{
           RowBox[{
            RowBox[{"u", "'"}], "[", "rmin", "]"}], "\[Equal]", 
           SuperscriptBox["10", 
            RowBox[{"-", "10"}]]}]}], "}"}], ",", "u", ",", 
        RowBox[{"{", 
         RowBox[{"r", ",", "rmin", ",", "rmax"}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"up", "=", 
      RowBox[{"u", "'"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Y", " ", "=", " ", 
      RowBox[{
       FractionBox[
        RowBox[{"up", "[", "r", "]"}], 
        RowBox[{"u", "[", "r", "]"}]], "/.", 
       RowBox[{"r", "\[Rule]", "r0"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Ksr", " ", "=", " ", 
      FractionBox[
       RowBox[{
        RowBox[{"Y", " ", "f0"}], " ", "-", "f0p"}], 
       RowBox[{
        RowBox[{"Y", " ", "g0"}], " ", "-", "g0p"}]]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"mu", " ", "=", " ", 
      RowBox[{
       FractionBox["1", "\[Pi]"], 
       RowBox[{"ArcTan", "[", "Ksr", "]"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Return", "[", "mu", "]"}]}]}], "\[IndentingNewLine]", 
   "]"}]}]], "Input",
 CellChangeTimes->{3.801842457413939*^9},
 CellLabel->
  "In[133]:=",ExpressionUUID->"bb9fe4f3-4950-4fe3-9b76-ee89ce470c31"],


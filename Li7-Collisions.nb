Cell[BoxData[{
 RowBox[{
  RowBox[{"\[Alpha]0sol", "=", 
   RowBox[{"Flatten", "[", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"NDSolve", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"\[Alpha]", "''"}], "[", "r", "]"}], "+", 
            RowBox[{
             RowBox[{"ksqr", "[", 
              RowBox[{"Etest", ",", "ltest", ",", "r"}], "]"}], 
             RowBox[{"\[Alpha]", "[", "r", "]"}]}], "-", 
            FractionBox["1", 
             SuperscriptBox[
              RowBox[{"\[Alpha]", "[", "r", "]"}], "3"]]}], "\[Equal]", "0"}],
           ",", 
          RowBox[{
           RowBox[{"\[Alpha]", "[", "rx", "]"}], "\[Equal]", 
           RowBox[{"BC1", "[", 
            RowBox[{"Etest", ",", "ltest", ",", "r", ",", "rx"}], "]"}]}], ",", 
          RowBox[{
           RowBox[{
            RowBox[{"\[Alpha]", "'"}], "[", "rx", "]"}], "\[Equal]", 
           RowBox[{"BC2", "[", 
            RowBox[{"Etest", ",", "ltest", ",", "r", ",", "rx"}], "]"}]}]}], 
         "}"}], ",", "\[Alpha]", ",", 
        RowBox[{"{", 
         RowBox[{"r", ",", "rx", ",", "rf"}], "}"}]}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"ltest", ",", "0", ",", "2"}], "}"}]}], "]"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Alpha]0fun", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"\[Alpha]", "/.", 
      RowBox[{"\[Alpha]0sol", "[", 
       RowBox[{"[", "i", "]"}], "]"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", 
       RowBox[{"Length", "[", "\[Alpha]0sol", "]"}]}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"nr", "=", "300"}], ";", 
  RowBox[{"rGrid", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"rx", "+", 
      RowBox[{
       SuperscriptBox[
        RowBox[{"(", 
         FractionBox[
          RowBox[{"i", "-", "1"}], 
          RowBox[{"nr", "-", "1"}]], ")"}], "3"], 
       RowBox[{"(", 
        RowBox[{"rf", "-", "rx"}], ")"}]}]}], ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", "nr"}], "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"PhaseIntTable", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"Flatten", "[", 
      RowBox[{"{", 
       RowBox[{"0", ",", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"NIntegrate", "[", 
           RowBox[{
            SuperscriptBox[
             RowBox[{
              RowBox[{"\[Alpha]0fun", "[", 
               RowBox[{"[", 
                RowBox[{"ltest", "+", "1"}], "]"}], "]"}], "[", "rp", "]"}], 
             RowBox[{"-", "2"}]], ",", 
            RowBox[{"{", 
             RowBox[{"rp", ",", 
              RowBox[{"rGrid", "[", 
               RowBox[{"[", 
                RowBox[{"i", "-", "1"}], "]"}], "]"}], ",", 
              RowBox[{"rGrid", "[", 
               RowBox[{"[", "i", "]"}], "]"}]}], "}"}]}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"i", ",", "2", ",", "nr"}], "}"}]}], "]"}]}], "}"}], "]"}],
      ",", 
     RowBox[{"{", 
      RowBox[{"ltest", ",", "0", ",", "2"}], "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"phaseintfun", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"Interpolation", "[", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"rGrid", "[", 
           RowBox[{"[", "i", "]"}], "]"}], ",", 
          RowBox[{"Total", "[", 
           RowBox[{"PhaseIntTable", "[", 
            RowBox[{"[", 
             RowBox[{
              RowBox[{"ltest", "+", "1"}], ",", 
              RowBox[{"1", ";;", "i"}]}], "]"}], "]"}], "]"}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", "1", ",", "nr"}], "}"}]}], "]"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"ltest", ",", "0", ",", "2"}], "}"}]}], "]"}]}], ";"}], 
"\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"phivals", "=", 
   RowBox[{"Transpose", "[", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"{", 
           RowBox[{
           "f0", ",", "g0", ",", "f0p", ",", "g0p", ",", "\[Chi]m", ",", 
            "\[Chi]mp"}], "}"}], "=", 
          RowBox[{"basepairs", "[", 
           RowBox[{"ltest", ",", "0.0", ",", 
            RowBox[{"\[Alpha]0fun", "[", 
             RowBox[{"[", 
              RowBox[{"ltest", "+", "1"}], "]"}], "]"}], ",", 
            RowBox[{"phaseintfun", "[", 
             RowBox[{"[", 
              RowBox[{"ltest", "+", "1"}], "]"}], "]"}], ",", "rf"}], "]"}]}],
          ";", 
         RowBox[{"{", 
          RowBox[{"rf", ",", 
           RowBox[{"ArcTan", "[", 
            RowBox[{"-", 
             FractionBox[
              RowBox[{"(", 
               RowBox[{
                RowBox[{"\[Chi]m", " ", "g0p"}], "-", 
                RowBox[{"\[Chi]mp", " ", "g0"}]}], ")"}], 
              RowBox[{"(", 
               RowBox[{
                RowBox[{"\[Chi]m", " ", "f0p"}], "-", 
                RowBox[{"\[Chi]mp", " ", "f0"}]}], ")"}]]}], "]"}]}], "}"}]}],
         ",", 
        RowBox[{"{", 
         RowBox[{"ltest", ",", "0", ",", "2"}], "}"}]}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"rf", ",", "rGrid"}], "}"}]}], "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Phi]final", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"phivals", "[", 
      RowBox[{"[", 
       RowBox[{"i", ",", "nr", ",", "2"}], "]"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", 
       RowBox[{"Length", "[", "phivals", "]"}]}], "}"}]}], "]"}]}], 
  ";"}]}], "Input",
 CellChangeTimes->{
  3.801264377192656*^9, {3.801264474127252*^9, 3.801264477756357*^9}, {

Cell[BoxData[
 RowBox[{
  RowBox[{"CalcTanEta", "[", 
   RowBox[{
   "l_", ",", "rx_", ",", "rf_", ",", "r_", ",", "\[CapitalEpsilon]_", ",", 
    "\[Phi]_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "f0", ",", "g0", ",", "f0p", ",", "g0p", ",", "\[Chi]m", ",", "\[Chi]mp",
       ",", "gs", ",", "fs", ",", "fsp", ",", "gsp", ",", "k", ",", 
      "tan\[Eta]", ",", "\[Alpha]fun", ",", "phaseint", ",", "\[Alpha]", ",", 
      "\[Alpha]p"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{"(*", 
     RowBox[{
      RowBox[{
       RowBox[{"{", 
        RowBox[{"\[Alpha]fun", ",", "phaseint"}], "}"}], "=", " ", 
       RowBox[{"CalcAlphaPhaseIntFun", "[", 
        RowBox[{
        "l", ",", "rx", ",", "rf", ",", "r", ",", "\[CapitalEpsilon]"}], 
        "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
        "f0", ",", "g0", ",", "f0p", ",", "g0p", ",", "\[Chi]m", ",", 
         "\[Chi]mp"}], "}"}], "=", 
       RowBox[{"basepairs", "[", 
        RowBox[{
        "l", ",", "\[Phi]", ",", "\[Alpha]fun", ",", "phaseint", ",", "r"}], 
        "]"}]}], ";"}], "*)"}], "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"\[Alpha]fun", " ", "=", " ", 
      RowBox[{"NDSolveValue", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"\[Alpha]", "''"}], "[", "r", "]"}], " ", "+", " ", 
            RowBox[{
             RowBox[{"ksqr", "[", 
              RowBox[{"\[CapitalEpsilon]", ",", "l", ",", "r"}], "]"}], 
             RowBox[{"\[Alpha]", "[", "r", "]"}]}], " ", "-", 
            FractionBox["1", 
             SuperscriptBox[
              RowBox[{"\[Alpha]", "[", "r", "]"}], "3"]]}], "\[Equal]", " ", 
           "0"}], ",", " ", 
          RowBox[{
           RowBox[{"\[Alpha]", "[", "rx", "]"}], " ", "\[Equal]", " ", 
           RowBox[{"BC1", "[", 
            RowBox[{"\[CapitalEpsilon]", ",", "l", ",", "r", ",", "rx"}], 
            "]"}]}], ",", 
          RowBox[{
           RowBox[{
            RowBox[{"\[Alpha]", "'"}], "[", "rx", "]"}], " ", "\[Equal]", " ", 
           RowBox[{"BC2", "[", 
            RowBox[{"\[CapitalEpsilon]", ",", "l", ",", "r", ",", "rx"}], 
            "]"}]}]}], "}"}], ",", "\[Alpha]", ",", 
        RowBox[{"{", 
         RowBox[{"r", ",", "rx", ",", "rf"}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"phaseint", "=", 
      RowBox[{"NIntegrate", "[", 
       RowBox[{
        SuperscriptBox[
         RowBox[{"\[Alpha]fun", "[", "rp", "]"}], 
         RowBox[{"-", "2"}]], ",", 
        RowBox[{"{", 
         RowBox[{"rp", ",", "rx", ",", "rf"}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"\[Alpha]p", "=", 
      RowBox[{"\[Alpha]fun", "'"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"g0", "=", 
      RowBox[{
       RowBox[{"-", 
        RowBox[{"\[Alpha]fun", "[", "rf", "]"}]}], 
       RowBox[{"Cos", "[", 
        RowBox[{"\[Phi]", "+", "phaseint"}], "]"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"g0p", "=", 
      RowBox[{
       RowBox[{
        FractionBox[
         RowBox[{"\[Alpha]p", "[", "rf", "]"}], 
         RowBox[{"\[Alpha]fun", "[", "rf", "]"}]], "g0"}], "+", 
       RowBox[{
        FractionBox["1", 
         SuperscriptBox[
          RowBox[{"\[Alpha]fun", "[", "rf", "]"}], "2"]], "f0"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"f0", "=", 
      RowBox[{
       RowBox[{"\[Alpha]fun", "[", "rf", "]"}], 
       RowBox[{"Sin", "[", 
        RowBox[{"\[Phi]", "+", "phaseint"}], "]"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"f0p", "=", 
      RowBox[{
       RowBox[{
        FractionBox[
         RowBox[{"\[Alpha]p", "[", "rf", "]"}], 
         RowBox[{"\[Alpha]fun", "[", "rf", "]"}]], "f0"}], "-", 
       RowBox[{

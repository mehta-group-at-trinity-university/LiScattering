Cell["\<\
Energy Grid For Positive Energies (used for open channel long-range \
parameters)\
\>", "Text",
 CellChangeTimes->{{3.801912837623645*^9, 3.801912843212142*^9}, {
  3.801912924632958*^9, 
  3.8019129674427767`*^9}},ExpressionUUID->"3f0f45e4-aa0b-491b-867f-\
d4921675e7dc"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"En", "=", "500"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Emin", " ", "=", " ", 
   SuperscriptBox["10", 
    RowBox[{"-", "16"}]]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Emax", " ", "=", "100"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"EGrid", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"Emin", "+", 
      RowBox[{
       SuperscriptBox[
        RowBox[{"(", 
         FractionBox[
          RowBox[{"i", "-", "1"}], 
          RowBox[{"En", "-", "1"}]], ")"}], "3"], 
       RowBox[{"(", 
        RowBox[{"Emax", "-", "Emin"}], ")"}]}]}], ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", "En"}], "}"}]}], "]"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.801912837623645*^9, 3.80191287392651*^9}, {
  3.8019129070744467`*^9, 3.801912912629758*^9}, {3.8019130321197987`*^9, 
  3.801913034025981*^9}, {3.8019134138682957`*^9, 3.801913414216798*^9}},
 CellLabel->
  "In[180]:=",ExpressionUUID->"81fbbaf7-09a4-4542-8841-4281dfe5a9fd"],

Cell[BoxData[
 RowBox[{
  RowBox[{"calcTanGamma", "[", 
   RowBox[{
   "l_", ",", "rx_", ",", "rf_", ",", "r_", ",", "\[CapitalEpsilon]_", ",", 
    "\[Phi]_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "\[Alpha]fun", ",", "phaseint", ",", "g0", ",", "g0p", ",", "f0", ",", 
      "f0p", ",", "\[Alpha]p", ",", "\[Alpha]", ",", "\[Kappa]", ",", "rp", ",",
       "gbound", ",", "gboundp", ",", "tan\[Gamma]"}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"\[Alpha]fun", " ", "=", " ", 
      RowBox[{"NDSolveValue", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"\[Alpha]", "''"}], "[", "r", "]"}], " ", "+", " ", 
            RowBox[{
             RowBox[{"ksqr", "[", 
              RowBox[{"\[CapitalEpsilon]", ",", "l", ",", "r"}], "]"}], 
             RowBox[{"\[Alpha]", "[", "r", "]"}]}], " ", "-", 
            FractionBox["1", 
             SuperscriptBox[
              RowBox[{"\[Alpha]", "[", "r", "]"}], "3"]]}], "\[Equal]", " ", 
           "0"}], ",", " ", 
          RowBox[{
           RowBox[{"\[Alpha]", "[", "rx", "]"}], " ", "\[Equal]", " ", 
           RowBox[{"BC1", "[", 
            RowBox[{"\[CapitalEpsilon]", ",", "l", ",", "r", ",", "rx"}], 
            "]"}]}], ",", 
          RowBox[{
           RowBox[{
            RowBox[{"\[Alpha]", "'"}], "[", "rx", "]"}], " ", "\[Equal]", " ", 
           RowBox[{"BC2", "[", 
            RowBox[{"\[CapitalEpsilon]", ",", "l", ",", "r", ",", "rx"}], 
            "]"}]}]}], "}"}], ",", "\[Alpha]", ",", 
        RowBox[{"{", 
         RowBox[{"r", ",", "rx", ",", "rf"}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"phaseint", "=", 
      RowBox[{"NIntegrate", "[", 
       RowBox[{
        SuperscriptBox[
         RowBox[{"\[Alpha]fun", "[", "rp", "]"}], 
         RowBox[{"-", "2"}]], ",", 
        RowBox[{"{", 
         RowBox[{"rp", ",", "rx", ",", "rf"}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"\[Alpha]p", "=", 
      RowBox[{"\[Alpha]fun", "'"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"g0", "=", 
      RowBox[{
       RowBox[{"-", 
        RowBox[{"\[Alpha]fun", "[", "rf", "]"}]}], 
       RowBox[{"Cos", "[", 
        RowBox[{"\[Phi]", "+", "phaseint"}], "]"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"g0p", "=", 
      RowBox[{
       RowBox[{
        FractionBox[
         RowBox[{"\[Alpha]p", "[", "rf", "]"}], 
         RowBox[{"\[Alpha]fun", "[", "rf", "]"}]], "g0"}], "+", 
       RowBox[{
        FractionBox["1", 
         SuperscriptBox[
          RowBox[{"\[Alpha]fun", "[", "rf", "]"}], "2"]], "f0"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"f0", "=", 
      RowBox[{
       RowBox[{"\[Alpha]fun", "[", "rf", "]"}], 
       RowBox[{"Sin", "[", 
        RowBox[{"\[Phi]", "+", "phaseint"}], "]"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"f0p", "=", 
      RowBox[{
       RowBox[{
        FractionBox[
         RowBox[{"\[Alpha]p", "[", "rf", "]"}], 
         RowBox[{"\[Alpha]fun", "[", "rf", "]"}]], "f0"}], "-", 
       RowBox[{
        FractionBox["1", 
         SuperscriptBox[
          RowBox[{"\[Alpha]fun", "[", "rf", "]"}], "2"]], "g0"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"\[Kappa]", "=", 
      SqrtBox[
       RowBox[{"-", "\[CapitalEpsilon]"}]]}], ";", "\[IndentingNewLine]", 
     RowBox[{"gbound", "=", 
      RowBox[{
       RowBox[{
        SqrtBox[
         RowBox[{
          FractionBox["\[Kappa]", "\[Pi]"], " ", "rp"}]], " ", 
        RowBox[{"BesselK", "[", 
         RowBox[{
          RowBox[{"l", "+", 
           RowBox[{"1", "/", "2"}]}], ",", 
          RowBox[{"\[Kappa]", " ", "rp"}]}], "]"}]}], "/.", 
       RowBox[{"rp", "\[Rule]", "rf"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"gboundp", "=", 
      RowBox[{
       RowBox[{"D", "[", 
        RowBox[{
         RowBox[{
          SqrtBox[
           RowBox[{
            FractionBox["\[Kappa]", "\[Pi]"], " ", "rp"}]], " ", 
          RowBox[{"BesselK", "[", 
           RowBox[{
            RowBox[{"l", "+", 
             RowBox[{"1", "/", "2"}]}], ",", 
            RowBox[{"\[Kappa]", " ", "rp"}]}], "]"}]}], ",", "rp"}], "]"}], "/.", 
       RowBox[{"rp", "\[Rule]", "rf"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"tan\[Gamma]", " ", "=", 
      RowBox[{"-", 
       FractionBox[
        RowBox[{
         RowBox[{"gbound", " ", "g0p"}], "-", 
         RowBox[{"gboundp", " ", "g0"}]}], 
        RowBox[{
         RowBox[{"gbound", " ", "f0p"}], " ", "-", " ", 
         RowBox[{"gboundp", " ", "f0"}]}]]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Return", "[", "tan\[Gamma]", "]"}]}]}], "\[IndentingNewLine]", 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.801843989509495*^9, 3.8018440786705647`*^9}, {
  3.8018441104421167`*^9, 3.801844305614551*^9}, {3.801919976878056*^9, 
  3.8019199811603928`*^9}},
 CellLabel->
  "In[184]:=",ExpressionUUID->"804051a3-739a-44c7-992c-139b619cfafb"],

Cell[BoxData[
 RowBox[{
  RowBox[{"gammaTable", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"-", 
        RowBox[{"EGrid", "[", 
         RowBox[{"[", "ii", "]"}], "]"}]}], ",", 
       RowBox[{"ArcTan", "[", 
        RowBox[{"calcTanGamma", "[", 
         RowBox[{"0", ",", "rx", ",", "rf", ",", "r", ",", 
          RowBox[{"-", 
           RowBox[{"EGrid", "[", 
            RowBox[{"[", "ii", "]"}], "]"}]}], ",", 
          RowBox[{"phi", "[", 
           RowBox[{"[", "1", "]"}], "]"}]}], "]"}], "]"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"ii", ",", "1", ",", 
       RowBox[{"Length", "[", "EGrid", "]"}]}], "}"}]}], "]"}]}], 
  ";"}]], "Input",
 CellChangeTimes->{{3.80184432191575*^9, 3.801844330442687*^9}, {
  3.801844361546097*^9, 3.801844378826516*^9}, {3.80191311552678*^9, 
  3.801913161231577*^9}, {3.810316883369773*^9, 3.8103168942569237`*^9}},
 CellLabel->
  "In[185]:=",ExpressionUUID->"661e24ff-0979-48e3-ae3c-cc80db4093b2"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ListPlot", "[", 

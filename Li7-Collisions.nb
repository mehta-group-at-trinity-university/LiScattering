Cell[CellGroupData[{

Cell["\<\
Single Channel QDT Calculation to Determine the Scattering Lengths and \
Quantum Defects of the Singlet and Triplet Potentials\
\>", "Subsection",
 CellChangeTimes->{{3.80118112131496*^9, 
  3.801181201218154*^9}},ExpressionUUID->"89cd3eff-b1a0-42d9-bc51-\
e73a0dff7621"],

Cell[TextData[{
 "We first define the (irregular) zero-energy solution ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[Chi]", "-"], "(", "r", ")"}], " "}], TraditionalForm]],
  ExpressionUUID->"c473d832-da6b-4dbf-894b-a2c51e89a149"],
 " for an ",
 Cell[BoxData[
  FormBox[
   FractionBox[
    RowBox[{"-", 
     SubscriptBox["C", "6"]}], 
    SuperscriptBox["r", "6"]], TraditionalForm]],ExpressionUUID->
  "c4660f15-ac3b-4d09-b936-ec63205426fc"],
 " potential (which will be used for constructing the Milne solutions) and \
the Riccati functions (which will be used later to calculate the \
positive-energy MQDT parameters \[Eta], \[ScriptCapitalA], and \
\[ScriptCapitalG]). "
}], "Text",
 CellChangeTimes->{{3.801181294537519*^9, 3.8011815008265667`*^9}, {
  3.8011815402276278`*^9, 
  3.8011817277316637`*^9}},ExpressionUUID->"26dd3a0c-e776-45ce-b3e8-\
99f7dad70da2"],


Cell[TextData[{
 "This code will reproduce the potential curves for the ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["X", "1"], 
    SuperscriptBox[
     SubscriptBox["\[CapitalSigma]", "g"], "+"]}], TraditionalForm]],
  ExpressionUUID->"084d717c-2cba-4da3-b426-c72b89d2df6e"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["a", "3"], 
    SuperscriptBox[
     SubscriptBox["\[CapitalSigma]", "u"], "+"]}], TraditionalForm]],
  ExpressionUUID->"15b7d036-775e-43af-abf3-204cfa45b38f"],
 "states of ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["", "7"], 
    SubscriptBox["Li", "2"]}], TraditionalForm]],ExpressionUUID->
  "1c719ad6-1dd8-4fc4-ac07-02016cd2f884"],
 " using the MLR model outlined in Le Roy et al. Chem. Phys. 131, 204309 \
(2009), Le Roy et al. Mol. Phys. 109, 3 (2011). and Le Roy and Dattani, Mol. \
Spec. 268 (2011). Parameters have units of energy in ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["cm", 
    RowBox[{"-", "1"}]], TraditionalForm]],ExpressionUUID->
  "d294f7ec-8fa9-4dc6-949a-3b4c1d970b9b"],
 "and units of length in \[Angstrom]. The final potentials have units of \
energy in Hartree and units of length in ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["a", "0"], TraditionalForm]],ExpressionUUID->
  "4dff73d8-e4c6-4084-a8b8-40b8a59cd8f4"],
 ". "
}], "Text",
 CellChangeTimes->{{3.8011770262895603`*^9, 3.8011770555959167`*^9}, {

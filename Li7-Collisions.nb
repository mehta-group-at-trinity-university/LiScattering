Cell[BoxData[
 RowBox[{
  RowBox[{"basepairs", "[", 
   RowBox[{
   "l_", ",", "\[Phi]_", ",", "\[Alpha]_", ",", "phaseint_", ",", "r_"}], 
   "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "\[Alpha]p", ",", "rp", ",", "f0", ",", "g0", ",", "f0p", ",", "g0p", ",",
       "\[Chi]m", ",", "\[Chi]mp"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"\[Alpha]p", "=", 
      RowBox[{"\[Alpha]", "'"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"g0", "=", 
      RowBox[{
       RowBox[{"-", " ", 
        RowBox[{"\[Alpha]", "[", "r", "]"}]}], 
       RowBox[{"Cos", "[", 
        RowBox[{"\[Phi]", "+", 
         RowBox[{"phaseint", "[", "r", "]"}]}], "]"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"f0", "=", " ", 
      RowBox[{
       RowBox[{"\[Alpha]", "[", "r", "]"}], 
       RowBox[{"Sin", "[", 
        RowBox[{"\[Phi]", "+", 
         RowBox[{"phaseint", "[", "r", "]"}]}], "]"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"f0p", "=", 
      RowBox[{
       RowBox[{
        FractionBox[
         RowBox[{"\[Alpha]p", "[", "r", "]"}], 
         RowBox[{"\[Alpha]", "[", "r", "]"}]], "f0"}], "-", 
       RowBox[{
        FractionBox["1", 
         SuperscriptBox[
          RowBox[{"\[Alpha]", "[", "r", "]"}], "2"]], "g0"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"g0p", "=", 
      RowBox[{
       RowBox[{
        FractionBox[
         RowBox[{"\[Alpha]p", "[", "r", "]"}], 
         RowBox[{"\[Alpha]", "[", "r", "]"}]], "g0"}], "+", 
       RowBox[{
        FractionBox["1", 
         SuperscriptBox[
          RowBox[{"\[Alpha]", "[", "r", "]"}], "2"]], "f0"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"\[Chi]m", "=", 
      RowBox[{"\[Chi]minus", "[", 
       RowBox[{"r", ",", "l"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"\[Chi]mp", "=", 
      RowBox[{"\[Chi]mprime", "[", 
       RowBox[{"r", ",", "l"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{
      "f0", ",", "g0", ",", "f0p", ",", "g0p", ",", "\[Chi]m", ",", 
       "\[Chi]mp"}], "}"}]}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.80118175042*^9, 3.8011818228579397`*^9}, {
  3.8011818555468063`*^9, 3.8011818888729897`*^9}, {3.801240035126779*^9, 
  3.801240055646796*^9}, {3.801307715548209*^9, 3.8013077415393143`*^9}, {
  3.8013089006608887`*^9, 3.801308913608148*^9}, {3.801314129619048*^9, 
  3.801314136832507*^9}, {3.801318258574345*^9, 3.801318262159737*^9}, {
  3.8013228270918283`*^9, 3.801322849094617*^9}, {3.801323331479535*^9, 
  3.801323335537909*^9}, {3.801476873990444*^9, 3.801476880076295*^9}, {
  3.8015631735253477`*^9, 3.801563177184333*^9}, {3.8019361205612793`*^9, 
  3.8019361241985483`*^9}},
 CellLabel->"In[72]:=",ExpressionUUID->"7bb6c7d4-cf56-42df-802b-7246d7e7f417"],

Cell["\<\
Module for calculating alpha and phase integral functions using the Milne \
phase-amplitude method. \
\>", "Text",
 CellChangeTimes->{{3.801181917667079*^9, 
  3.801181947905138*^9}},ExpressionUUID->"bca64d6a-4dbd-43d8-85ca-\
e5a1eb5a57b2"],

Cell[BoxData[
 RowBox[{
  RowBox[{"CalcAlphaPhaseIntFun2", "[", 
   RowBox[{
   "\[CapitalEpsilon]_", ",", "l_", ",", "rx_", ",", "rf_", ",", "r_", ",", 
    "nr_", ",", "\[Mu]_", ",", "C6_", ",", "C8_", ",", "C10_"}], "]"}], ":=", 
  " ", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "k", ",", "bC1", ",", "bC2", ",", " ", "rGrid", ",", "PhaseIntTable", ",",
       "rp", ",", "PhaseIntFun", ",", "\[Alpha]fun", ",", "\[Alpha]"}], "}"}],
     ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"k", "=", 
      RowBox[{"Sqrt", "[", 
       RowBox[{"2", " ", "\[Mu]", " ", 
        RowBox[{"(", 
         RowBox[{"\[CapitalEpsilon]", "+", 
          FractionBox["C6", 
           SuperscriptBox["r", "6"]], "+", 
          FractionBox["C8", 
           SuperscriptBox["r", "8"]], "+", 
          FractionBox["C10", 
           SuperscriptBox["r", "8"]], "-", 
          FractionBox[
           RowBox[{"l", 
            RowBox[{"(", 
             RowBox[{"l", "+", "1"}], ")"}]}], 
           RowBox[{"2", " ", "\[Mu]", " ", 
            SuperscriptBox["r", "2"]}]]}], ")"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"bC1", " ", "=", " ", 
      RowBox[{
       FractionBox["1", 
        RowBox[{"Sqrt", "[", 
         RowBox[{"2", "\[Mu]", 
          SuperscriptBox[
           RowBox[{"(", 
            RowBox[{"\[CapitalEpsilon]", " ", "+", " ", 
             FractionBox["C6", 
              SuperscriptBox["r", "6"]], "+", 
             FractionBox["C8", 
              SuperscriptBox["r", "8"]], "+", 
             FractionBox["C10", 
              SuperscriptBox["r", "8"]], "-", 
             FractionBox[
              RowBox[{"l", 
               RowBox[{"(", 
                RowBox[{"l", "+", "1"}], ")"}]}], 
              SuperscriptBox["r", "2"]]}], ")"}], 
           RowBox[{"1", "/", "2"}]]}], "]"}]], "/.", 
       RowBox[{"r", "\[Rule]", "rx"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"bC2", " ", "=", " ", 
      RowBox[{
       RowBox[{"D", "[", 
        RowBox[{
         FractionBox["1", 
          RowBox[{"Sqrt", "[", 
           RowBox[{"2", "\[Mu]", 
            SuperscriptBox[
             RowBox[{"(", 
              RowBox[{"\[CapitalEpsilon]", " ", "+", " ", 
               FractionBox["C6", 
                SuperscriptBox["r", "6"]], "+", 
               FractionBox["C8", 
                SuperscriptBox["r", "8"]], "+", 
               FractionBox["C10", 
                SuperscriptBox["r", "8"]], "-", 
               FractionBox[
                RowBox[{"l", 
                 RowBox[{"(", 
                  RowBox[{"l", "+", "1"}], ")"}]}], 
                SuperscriptBox["r", "2"]]}], ")"}], 
             RowBox[{"1", "/", "2"}]]}], "]"}]], ",", "r"}], "]"}], "/.", 
       RowBox[{"r", "\[Rule]", "rx"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"\[Alpha]fun", " ", "=", " ", 
      RowBox[{"NDSolveValue", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"\[Alpha]", "''"}], "[", "r", "]"}], "+", " ", 
            RowBox[{
             SuperscriptBox["k", "2"], " ", 
             RowBox[{"\[Alpha]", "[", "r", "]"}]}], "-", 
            FractionBox["1", 
             SuperscriptBox[
              RowBox[{"\[Alpha]", "[", "r", "]"}], "3"]]}], "\[Equal]", " ", 
           "0"}], ",", 
          RowBox[{
           RowBox[{"\[Alpha]", "[", "rx", "]"}], "\[Equal]", " ", "bC1"}], ",", 
          RowBox[{
           RowBox[{
            RowBox[{"\[Alpha]", "'"}], "[", "rx", "]"}], "\[Equal]", " ", 
           "bC2"}]}], "}"}], ",", "\[Alpha]", ",", 
        RowBox[{"{", 
         RowBox[{"r", ",", "rx", ",", "rf"}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"rGrid", " ", "=", " ", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"rx", "+", 
         RowBox[{
          SuperscriptBox[
           RowBox[{"(", 
            FractionBox[
             RowBox[{"i", "-", "1"}], 
             RowBox[{"nr", "-", "1"}]], ")"}], "3"], 
          RowBox[{"(", 
           RowBox[{"rf", "-", "rx"}], ")"}]}]}], ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", "1", ",", "nr"}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"PhaseIntTable", " ", "=", " ", 
      RowBox[{"Flatten", "[", 
       RowBox[{"{", 
        RowBox[{"0", ",", 
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"NIntegrate", "[", 
            RowBox[{
             FractionBox["1", 
              SuperscriptBox[
               RowBox[{"\[Alpha]fun", "[", "rp", "]"}], "2"]], ",", 
             RowBox[{"{", 
              RowBox[{"rp", ",", 
               RowBox[{"rGrid", "[", 
                RowBox[{"[", 
                 RowBox[{"i", "-", "1"}], "]"}], "]"}], ",", 
               RowBox[{"rGrid", "[", 
                RowBox[{"[", "i", "]"}], "]"}]}], "}"}]}], "]"}], ",", 
           RowBox[{"{", 
            RowBox[{"i", ",", "2", ",", "nr"}], "}"}]}], "]"}]}], "}"}], 
       "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"PhaseIntFun", " ", "=", " ", 
      RowBox[{"Interpolation", "[", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"rGrid", "[", 
            RowBox[{"[", "i", "]"}], "]"}], ",", 
           RowBox[{"Total", "[", 
            RowBox[{"PhaseIntTable", "[", 
             RowBox[{"[", 
              RowBox[{"1", ";;", "i"}], "]"}], "]"}], "]"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", "1", ",", "nr"}], "}"}]}], "]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Return", "[", 
      RowBox[{"{", 
       RowBox[{"\[Alpha]fun", ",", "PhaseIntFun"}], "}"}], "]"}]}]}], 
   "\[IndentingNewLine]", "]"}]}]], "Input",
 CellChangeTimes->{{3.801181964245366*^9, 3.801181966761056*^9}, {
   3.8012663753147163`*^9, 3.801266379170024*^9}, 3.801578284366228*^9, {
   3.801590755839685*^9, 3.80159082910196*^9}, {3.8018225108615637`*^9, 
   3.801822527082657*^9}, {3.801822785866191*^9, 3.8018227866462*^9}, {
   3.801825566850018*^9, 3.801825581063863*^9}, {3.801831626199534*^9, 
   3.801831641989813*^9}, {3.801832776097081*^9, 3.801832797727099*^9}, {
   3.801833273090164*^9, 3.801833277151944*^9}, {3.801846847139303*^9, 
   3.8018469741402807`*^9}, {3.801847094385386*^9, 3.8018471717381477`*^9}, {
   3.801847615190763*^9, 3.801847618075306*^9}, {3.801847898273738*^9, 
   3.8018479529364634`*^9}, {3.801849765300591*^9, 3.801849838202086*^9}, {
   3.801849932790154*^9, 3.801849979183359*^9}, {3.8019068293048983`*^9, 
   3.801906856456181*^9}, {3.801952961833027*^9, 3.801953021314768*^9}},
 CellLabel->"In[73]:=",ExpressionUUID->"493f7954-8a44-44c6-aa23-a7ee6de07be2"],


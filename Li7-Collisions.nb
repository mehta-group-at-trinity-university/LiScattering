             RowBox[{
              RowBox[{"-", 
               FractionBox["1", 
                RowBox[{"2", " ", "\[Mu]"}]]}], 
              RowBox[{
               RowBox[{"u", "''"}], "[", "r", "]"}]}], "+", 
             RowBox[{
              RowBox[{"SingletLi7", "[", 
               RowBox[{"r", ",", "a"}], "]"}], " ", 
              RowBox[{"u", "[", "r", "]"}]}]}], "\[Equal]", 
            RowBox[{"\[CapitalEpsilon]test", " ", 
             RowBox[{"u", "[", "r", "]"}]}]}], ",", 
           RowBox[{
            RowBox[{"u", "[", "rmin", "]"}], "\[Equal]", "0"}], ",", 
           RowBox[{
            RowBox[{
             RowBox[{"u", "'"}], "[", "rmin", "]"}], "\[Equal]", 
            SuperscriptBox["10", 
             RowBox[{"-", "10"}]]}]}], "}"}], ",", "u", ",", 
         RowBox[{"{", 
          RowBox[{"r", ",", "rmin", ",", "rmax"}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"u1", "=", 
       RowBox[{
        RowBox[{"u", "[", "r1", "]"}], "/.", 
        RowBox[{"sol", "[", 
         RowBox[{"[", "1", "]"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"u2", "=", 
       RowBox[{
        RowBox[{"u", "[", "r2", "]"}], "/.", 
        RowBox[{"sol", "[", 
         RowBox[{"[", "1", "]"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"CotanDelta", "=", 
       FractionBox[
        RowBox[{
         RowBox[{
          RowBox[{"-", "u2"}], " ", 
          RowBox[{"Cos", "[", 
           RowBox[{"k", " ", "r1"}], "]"}]}], "+", 
         RowBox[{"u1", " ", 
          RowBox[{"Cos", "[", 
           RowBox[{"k", " ", "r2"}], "]"}]}]}], 
        RowBox[{
         RowBox[{"u2", " ", 
          RowBox[{"Sin", "[", 
           RowBox[{"k", " ", "r1"}], "]"}]}], "-", 
         RowBox[{"u1", " ", 
          RowBox[{"Sin", "[", 
           RowBox[{"k", " ", "r2"}], "]"}]}]}]]}], ";", "\[IndentingNewLine]", 
      RowBox[{"Return", "[", "CotanDelta", "]"}]}]}], "\[IndentingNewLine]", 
    "]"}]}], "\n"}], "\n", 
 RowBox[{
  RowBox[{"CalcERESinglet", "[", 
   RowBox[{
   "rmax_", ",", "rmin_", ",", "\[CapitalEpsilon]Min_", ",", 
    "\[CapitalEpsilon]Max_", ",", "\[Mu]_", ",", "a_"}], "]"}], ":=", 
  "\[IndentingNewLine]", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "EREData", ",", "ascat", ",", "reff", ",", "A", ",", "B", ",", "fitpars",
       ",", "dE"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"dE", "=", 
      FractionBox[
       RowBox[{"(", 
        RowBox[{"\[CapitalEpsilon]Max", "-", "\[CapitalEpsilon]Min"}], ")"}], 
       "10"]}], ";", "\[IndentingNewLine]", 
     RowBox[{"EREData", "=", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"2", "\[Mu]", " ", "\[CapitalEpsilon]test"}], ",", 
          RowBox[{
           SqrtBox[
            RowBox[{"2", "\[Mu]", " ", "\[CapitalEpsilon]test"}]], 
           RowBox[{"CalcCotanDeltaSinglet", "[", 
            RowBox[{
            "\[CapitalEpsilon]test", ",", "rmax", ",", "rmin", ",", "\[Mu]", ",", \
"a"}], "]"}]}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{
         "\[CapitalEpsilon]test", ",", "\[CapitalEpsilon]Min", ",", 
          "\[CapitalEpsilon]Max", ",", "dE"}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"fitpars", "=", 
      RowBox[{"FindFit", "[", 
       RowBox[{"EREData", ",", 
        RowBox[{"A", "+", 
         RowBox[{"B", " ", "ksqr"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"A", ",", "B"}], "}"}], ",", "ksqr"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"ascat", "=", 
      RowBox[{
       FractionBox[
        RowBox[{"-", "1"}], "A"], "/.", "fitpars"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"reff", "=", 
      RowBox[{
       RowBox[{"2", "B"}], "/.", "fitpars"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Return", "[", 
      RowBox[{"{", 
       RowBox[{"ascat", ",", "reff", ",", "EREData"}], "}"}], "]"}]}]}], 
   "\[IndentingNewLine]", "]"}]}]}], "Input",
 CellChangeTimes->{{3.80303062047254*^9, 3.803030653884696*^9}},
 CellLabel->"In[86]:=",ExpressionUUID->"2ee78543-00b0-4fe5-82b4-a60580a024cb"],


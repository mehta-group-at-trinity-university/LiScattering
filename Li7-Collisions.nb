de875f8e8705"],

Cell["\<\
J. P. Burke. \[OpenCurlyDoubleQuote]Theoretical Investigation of Cold Alkali \
Atom Collisions.\[CloseCurlyDoubleQuote] University of Colorado, PhD Thesis \
(1999)\
\>", "Text",
 CellChangeTimes->{{3.7995005577984047`*^9, 
  3.7995006049713383`*^9}},ExpressionUUID->"79f58acc-2fc0-40a3-a984-\
33065514a230"],

Cell[TextData[StyleBox["From Section 4.3: Frame Transformation Approximation \
", "Subsubsection"]], "Text",
 CellChangeTimes->{{3.7995005577984047`*^9, 3.799500610725994*^9}},
 TextAlignment->Center,ExpressionUUID->"cec76ae8-96c6-4b2d-b115-a0c9c8d57e42"],

Cell["\<\
The short range reaction matrix is approximated by the frame transformation \
(FT) expression \
\>", "Text",
 CellChangeTimes->{{3.7995005577984047`*^9, 3.799500574222416*^9}, {
  3.799500675408061*^9, 
  3.799500703204238*^9}},ExpressionUUID->"3f94397d-8603-433e-8e86-\
7f9c67d6942e"],

Cell[BoxData[
 FormBox[
  RowBox[{
   SubscriptBox[
    RowBox[{"(", 
     SuperscriptBox["K", "sr"], ")"}], 
    RowBox[{"i", ",", 
     RowBox[{"i", "'"}]}]], "=", 
   RowBox[{
    SubscriptBox["\[Sum]", "\[Lambda]"], 
    RowBox[{
     RowBox[{"\[LeftAngleBracket]", 
      RowBox[{"i", "|", "\[Lambda]"}], "\[RightAngleBracket]"}], 
     RowBox[{"tan", "(", 
      RowBox[{
       SubscriptBox["\[Pi]\[Mu]", "\[Lambda]"], "(", 
       OverscriptBox[
        SubscriptBox["\[Epsilon]", "\[Lambda]"], "_"], ")"}], ")"}], 
     RowBox[{"\[LeftAngleBracket]", 
      RowBox[{"\[Lambda]", "|", 
       RowBox[{"i", "'"}]}], "\[RightAngleBracket]"}]}]}]}], 
  TraditionalForm]], "EquationNumbered",
 CellChangeTimes->{{3.7995005577984047`*^9, 3.799500574222416*^9}, {
  3.799500675408061*^9, 3.799501036246176*^9}, {3.799501114608697*^9, 
  3.799501164653214*^9}},ExpressionUUID->"c0fe51ea-fe09-4bb7-acaf-\
15b0ce6e30bc"],

Cell[TextData[{
 "where \[LeftAngleBracket]",
 StyleBox["i",
  FontSlant->"Italic"],
 "|\[Lambda]\[RightAngleBracket] represents the unitary transformation that \
connects the short range singlet-triplet, or molecular, basis ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"\[Lambda]"},
     "Ket"], "=", 
    TemplateBox[{
      RowBox[{
        RowBox[{"(", 
          RowBox[{
            SubscriptBox["s", "a"], 
            SubscriptBox["s", "b"]}], ")"}], 
        RowBox[{"S", "(", 
          RowBox[{
            SubscriptBox["i", "a"], 
            SubscriptBox["i", "b"]}], ")"}], "I", " ", "F", " ", "M"}]},
     "Ket"]}], TraditionalForm]],ExpressionUUID->
  "171956ae-76f6-4c7f-9a16-f82a2b4c53df"],
 " with the asymptotic hyperfine basis ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"i"},
     "Ket"], "=", 
    TemplateBox[{
      RowBox[{
        RowBox[{"(", 
          RowBox[{
            SubscriptBox["s", "a"], 
            SubscriptBox["i", "a"]}], ")"}], 
        RowBox[{
          SubscriptBox["f", "a"], "(", 
          RowBox[{
            SubscriptBox["s", "b"], 
            SubscriptBox["i", "b"]}], ")"}], 
        SubscriptBox["f", "b"], " ", "F", " ", "M"}]},
     "Ket"]}], TraditionalForm]],ExpressionUUID->
  "7ebfcd6a-aaf7-4569-b033-33242ae1ab4b"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox[
     SubscriptBox["\[Epsilon]", "\[Lambda]"], "_"], "=", 
    RowBox[{
     RowBox[{
      SubscriptBox["\[Sum]", "i"], 
      SubscriptBox["\[Epsilon]", "i"]}], "|", 
     RowBox[{"\[LeftAngleBracket]", 
      RowBox[{
       StyleBox["i",
        FontSlant->"Italic"], "|", "\[Lambda]"}], "\[RightAngleBracket]"}], 
     SuperscriptBox["|", "2"]}]}], TraditionalForm]],ExpressionUUID->
  "7bff7112-def3-4e64-ace7-c5e31ae1ec37"],
 ". Moreover, \[LeftAngleBracket]",
 StyleBox["i",
  FontSlant->"Italic"],
 "|\[Lambda]\[RightAngleBracket] is understood to the transformation between \
symmetrized kets if the particles are identical. "
}], "Text",
 CellChangeTimes->{{3.7995005577984047`*^9, 3.799500574222416*^9}, {
  3.799500675408061*^9, 3.7995010721720657`*^9}, {3.799501167002468*^9, 
  3.799501207353496*^9}, {3.7995012667269707`*^9, 3.799501495947938*^9}, {
  3.799501872800337*^9, 3.7995018728022633`*^9}, {3.799501999306054*^9, 
  3.799502091081799*^9}},ExpressionUUID->"b5e045c6-c05e-48d8-93a4-\
f11485353dea"],

Cell[CellGroupData[{

Cell["Energy-Independent FT Approximation", "Subsubsubsection",
 CellChangeTimes->{{3.7995005577984047`*^9, 3.799500574222416*^9}, {
  3.799500675408061*^9, 3.7995010721720657`*^9}, {3.799501167002468*^9, 
  3.799501207353496*^9}, {3.7995012667269707`*^9, 3.799501495947938*^9}, {
  3.799501912157251*^9, 
  3.7995019280246487`*^9}},ExpressionUUID->"b9a14a4a-d652-4e49-8c2e-\
f3bb31c86772"],

Cell["\<\
In this approximation, only the zero energy values of the quantum defects are \
used and Equation 41 simplifies to\
\>", "Text",
 CellChangeTimes->{{3.7995005577984047`*^9, 3.799500574222416*^9}, {
  3.799500675408061*^9, 3.7995010721720657`*^9}, {3.799501167002468*^9, 
  3.799501207353496*^9}, {3.7995012667269707`*^9, 3.799501495947938*^9}, {
  3.799501912157251*^9, 3.799501981837487*^9}, {3.799502105513714*^9, 
  3.799502123730673*^9}},ExpressionUUID->"e12661da-116b-4686-a6da-\
bf635a42cebc"],

Cell[BoxData[
 FormBox[
  RowBox[{
   SubscriptBox[
    RowBox[{"(", 
     SuperscriptBox["K", "sr"], ")"}], 
    RowBox[{"i", ",", 
     RowBox[{"i", "'"}]}]], "=", 
   RowBox[{
    SubscriptBox["\[Sum]", "\[Lambda]"], 
    RowBox[{
     RowBox[{"\[LeftAngleBracket]", 
      RowBox[{"i", "|", "\[Lambda]"}], "\[RightAngleBracket]"}], 
     RowBox[{"tan", "(", 
      RowBox[{
       SubscriptBox["\[Pi]\[Mu]", "\[Lambda]"], "(", "0", ")"}], ")"}], 
     RowBox[{
      RowBox[{"\[LeftAngleBracket]", 
       RowBox[{"\[Lambda]", "|", 
        RowBox[{"i", "'"}]}], "\[RightAngleBracket]"}], ".", " "}]}]}]}], 
  TraditionalForm]], "EquationNumbered",
 CellChangeTimes->{{3.7995005577984047`*^9, 3.799500574222416*^9}, {
  3.799500675408061*^9, 3.7995010721720657`*^9}, {3.799501167002468*^9, 
  3.799501207353496*^9}, {3.7995012667269707`*^9, 3.799501495947938*^9}, {
  3.799501912157251*^9, 3.799501981837487*^9}, {3.799502105513714*^9, 
  3.7995021748384333`*^9}},ExpressionUUID->"d976649b-df76-4762-b24a-\
da62640947e6"],

Cell[BoxData[
 FormBox[
  RowBox[{"K", " ", "=", " ", 
   RowBox[{
    SuperscriptBox[
     RowBox[{
      SuperscriptBox["A", 
       RowBox[{"1", "/", "2"}]], "(", 
      RowBox[{
       SuperscriptBox[
        OverscriptBox["K", "~"], 
        RowBox[{"-", "1"}]], "+", "G"}], ")"}], 
     RowBox[{"-", "1"}]], 
    SuperscriptBox["A", 
     RowBox[{"1", "/", "2"}]]}]}], TraditionalForm]], "EquationNumbered",
 CellChangeTimes->{{3.7995005577984047`*^9, 3.799500574222416*^9}, {
  3.799500675408061*^9, 3.7995010721720657`*^9}, {3.799501167002468*^9, 
  3.799501207353496*^9}, {3.7995012667269707`*^9, 3.799501495947938*^9}, {
  3.799501912157251*^9, 3.799501981837487*^9}, {3.799502105513714*^9, 
  3.799502206985324*^9}, {3.7995022967405443`*^9, 3.799502421870736*^9}, {
  3.7995025432954206`*^9, 3.799502760665102*^9}, {3.799503100908059*^9, 
  3.799503319463414*^9}, {3.800628277864485*^9, 
  3.8006282789777412`*^9}},ExpressionUUID->"cb3dd8ed-3350-4b0f-a5cd-\
36769c01c59f"],

Cell[BoxData[
 FormBox[
  RowBox[{"S", " ", "=", 
   RowBox[{
    SuperscriptBox["e", "i\[Eta]"], " ", 
    FractionBox[
     RowBox[{"1", "+", 
      RowBox[{"i", " ", "K"}]}], 
     RowBox[{"1", "-", 
      RowBox[{"i", " ", "K"}]}]], 
    RowBox[{
     SuperscriptBox["e", "i\[Eta]"], "."}]}]}], 
  TraditionalForm]], "EquationNumbered",
 CellChangeTimes->{{3.7995005577984047`*^9, 3.799500574222416*^9}, {
   3.799500675408061*^9, 3.7995010721720657`*^9}, {3.799501167002468*^9, 
   3.799501207353496*^9}, {3.7995012667269707`*^9, 3.799501495947938*^9}, {
   3.799501912157251*^9, 3.799501981837487*^9}, {3.799502105513714*^9, 
   3.799502206985324*^9}, {3.7995022967405443`*^9, 3.799502421870736*^9}, {
   3.7995025432954206`*^9, 3.799502760665102*^9}, {3.799503100908059*^9, 
   3.7995033194587517`*^9}, {3.7995033949651613`*^9, 3.7995034511647997`*^9}, 
   3.799503918853026*^9, {3.799504088523699*^9, 
   3.7995040898896227`*^9}},ExpressionUUID->"9233dbdf-a2b0-4515-8454-\
50b8bee47e83"],

Cell[TextData[{
 "Burke explains that the energy-independent FT approximation produces an \
accurate ",
 StyleBox["S",
  FontSlant->"Italic"],
 "-matrix \[OpenCurlyDoubleQuote]provided no resonances or quantum \
interferences are present\[CloseCurlyDoubleQuote] and an ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["K", "sr"], TraditionalForm]],ExpressionUUID->
  "93c53ed7-fe79-47ee-9d55-29cea627eed5"],
 "-matrix which predicts quantum effects \[OpenCurlyDoubleQuote]at a field or \
energy value slightly shifted from its true location.\[CloseCurlyDoubleQuote] \
Burke also writes that \[OpenCurlyDoubleQuote]the accuracy of the FT \
approximation diminishes somewhat with increased hyperfine splitting and with \
increased mass...but [it] does in general, produce excellent results for Li \
through Rb\[CloseCurlyDoubleQuote] with a few exceptions. "
}], "Text",
 CellChangeTimes->{{3.7995039790836887`*^9, 3.799504018996377*^9}, {
  3.799504059734967*^9, 3.799504234631221*^9}, {3.799504348145061*^9, 
  3.799504453279482*^9}, {3.799514566198949*^9, 
  3.799514567382989*^9}},ExpressionUUID->"bb6ff98f-e1d4-4d83-861b-\
a01b8ed1b892"],


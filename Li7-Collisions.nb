Cell[BoxData[
 RowBox[{
  RowBox[{"CalcY", "[", 
   RowBox[{
   "\[CapitalEpsilon]_", ",", "l_", ",", "rmin_", ",", "rmax_", ",", "\[Mu]_",
     ",", "r0_", ",", "U_", ",", "r_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"Y", ",", "u", ",", "\[Psi]in", ",", "\[Psi]inp", ",", "rp"}], 
     "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"\[Psi]in", "=", 
      RowBox[{"NDSolveValue", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{
             FractionBox[
              RowBox[{"-", "1"}], 
              RowBox[{"2", " ", "\[Mu]"}]], 
             RowBox[{
              RowBox[{"u", "''"}], "[", "r", "]"}]}], "+", " ", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{
               RowBox[{"U", "[", "r", "]"}], "+", 
               FractionBox[
                RowBox[{"l", 
                 RowBox[{"(", 
                  RowBox[{"l", "+", "1"}], ")"}]}], 
                RowBox[{"2", " ", "\[Mu]", " ", 
                 SuperscriptBox["r", "2"]}]]}], ")"}], "*", 
             RowBox[{"u", "[", "r", "]"}]}]}], "\[Equal]", 
           RowBox[{"\[CapitalEpsilon]", " ", 
            RowBox[{"u", "[", "r", "]"}]}]}], ",", 
          RowBox[{
           RowBox[{"u", "[", "rmin", "]"}], "\[Equal]", "0"}], ",", 
          RowBox[{
           RowBox[{
            RowBox[{"u", "'"}], "[", "rmin", "]"}], "\[Equal]", 
           SuperscriptBox["10", 
            RowBox[{"-", "10"}]]}]}], "}"}], ",", "u", ",", 
        RowBox[{"{", 
         RowBox[{"r", ",", "rmin", ",", "rmax"}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"\[Psi]inp", "=", 
      RowBox[{"\[Psi]in", "'"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Y", " ", "=", " ", 
      RowBox[{
       FractionBox[
        RowBox[{"\[Psi]inp", "[", "r", "]"}], 
        RowBox[{"\[Psi]in", "[", "r", "]"}]], "/.", 
       RowBox[{"r", "\[Rule]", "r0"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Return", "[", "Y", "]"}]}]}], "\[IndentingNewLine]", 
   "]"}]}]], "Input",
 CellChangeTimes->{
  3.8011820234284353`*^9, {3.801847216553142*^9, 3.801847230142907*^9}, {
   3.801847764394816*^9, 3.801847822882127*^9}},
 CellLabel->"In[74]:=",ExpressionUUID->"83d7e6a4-9bac-4891-b9aa-f5da2ded4967"],


Cell[BoxData[
 RowBox[{
  RowBox[{"CalcG", "[", 
   RowBox[{
   "l_", ",", "rx_", ",", "rf_", ",", "r_", ",", "\[CapitalEpsilon]_", ",", 
    "\[Phi]_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "f0", ",", "g0", ",", "f0p", ",", "g0p", ",", "\[Chi]m", ",", "\[Chi]mp",
       ",", "k", ",", "tan\[Eta]", ",", "G", ",", "fs", ",", "fsp", ",", "gs",
       ",", "gsp", ",", "\[Alpha]fun", ",", "phaseint", ",", "Wfsf0", ",", 
      "Wgsf0", ",", "Wfsg0", ",", "Wgsg0", ",", "\[Alpha]", ",", 
      "\[Alpha]p"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{"(*", 
     RowBox[{
      RowBox[{
       RowBox[{"{", 
        RowBox[{"\[Alpha]fun", ",", "phaseint"}], "}"}], "=", " ", 
       RowBox[{"CalcAlphaPhaseIntFun", "[", 
        RowBox[{
        "l", ",", "rx", ",", "rf", ",", "r", ",", "\[CapitalEpsilon]"}], 
        "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
        "f0", ",", "g0", ",", "f0p", ",", "g0p", ",", "\[Chi]m", ",", 
         "\[Chi]mp"}], "}"}], "=", 
       RowBox[{"basepairs", "[", 
        RowBox[{
        "l", ",", "\[Phi]", ",", "\[Alpha]fun", ",", "phaseint", ",", "r"}], 
        "]"}]}], ";"}], "*)"}], "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"\[Alpha]fun", " ", "=", " ", 
      RowBox[{"NDSolveValue", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"\[Alpha]", "''"}], "[", "r", "]"}], " ", "+", " ", 
            RowBox[{
             RowBox[{"ksqr", "[", 
              RowBox[{"\[CapitalEpsilon]", ",", "l", ",", "r"}], "]"}], 
             RowBox[{"\[Alpha]", "[", "r", "]"}]}], " ", "-", 
            FractionBox["1", 
             SuperscriptBox[
              RowBox[{"\[Alpha]", "[", "r", "]"}], "3"]]}], "\[Equal]", " ", 
           "0"}], ",", " ", 
          RowBox[{
           RowBox[{"\[Alpha]", "[", "rx", "]"}], " ", "\[Equal]", " ", 
           RowBox[{"BC1", "[", 
            RowBox[{"\[CapitalEpsilon]", ",", "l", ",", "r", ",", "rx"}], 
            "]"}]}], ",", 
          RowBox[{
           RowBox[{
            RowBox[{"\[Alpha]", "'"}], "[", "rx", "]"}], " ", "\[Equal]", " ", 
           RowBox[{"BC2", "[", 
            RowBox[{"\[CapitalEpsilon]", ",", "l", ",", "r", ",", "rx"}], 
            "]"}]}]}], "}"}], ",", "\[Alpha]", ",", 
        RowBox[{"{", 
         RowBox[{"r", ",", "rx", ",", "rf"}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"phaseint", "=", 
      RowBox[{"NIntegrate", "[", 
       RowBox[{
        SuperscriptBox[
         RowBox[{"\[Alpha]fun", "[", "rp", "]"}], 
         RowBox[{"-", "2"}]], ",", 
        RowBox[{"{", 
         RowBox[{"rp", ",", "rx", ",", "rf"}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"\[Alpha]p", "=", 
      RowBox[{"\[Alpha]fun", "'"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"g0", "=", 
      RowBox[{
       RowBox[{"-", 
        RowBox[{"\[Alpha]fun", "[", "rf", "]"}]}], 
       RowBox[{"Cos", "[", 
        RowBox[{"\[Phi]", "+", "phaseint"}], "]"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"g0p", "=", 
      RowBox[{
       RowBox[{
        FractionBox[
         RowBox[{"\[Alpha]p", "[", "rf", "]"}], 
         RowBox[{"\[Alpha]fun", "[", "rf", "]"}]], "g0"}], "+", 
       RowBox[{
        FractionBox["1", 
         SuperscriptBox[
          RowBox[{"\[Alpha]fun", "[", "rf", "]"}], "2"]], "f0"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"f0", "=", 
      RowBox[{
       RowBox[{"\[Alpha]fun", "[", "rf", "]"}], 
       RowBox[{"Sin", "[", 
        RowBox[{"\[Phi]", "+", "phaseint"}], "]"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"f0p", "=", 
      RowBox[{
       RowBox[{
        FractionBox[
         RowBox[{"\[Alpha]p", "[", "rf", "]"}], 
         RowBox[{"\[Alpha]fun", "[", "rf", "]"}]], "f0"}], "-", 
       RowBox[{
        FractionBox["1", 
         SuperscriptBox[
          RowBox[{"\[Alpha]fun", "[", "rf", "]"}], "2"]], "g0"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"k", " ", "=", " ", 
      RowBox[{"Sqrt", "[", " ", "\[CapitalEpsilon]", "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"fs", " ", "=", " ", 
      RowBox[{"f", "[", 
       RowBox[{"l", ",", "k", ",", "r"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"fsp", "=", 
      RowBox[{"dfdr", "[", 
       RowBox[{"l", ",", "k", ",", "r"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"gs", "=", 
      RowBox[{"g", "[", 
       RowBox[{"l", ",", "k", ",", "r"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"gsp", "=", 
      RowBox[{"dgdr", "[", 
       RowBox[{"l", ",", "k", ",", "r"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Wfsf0", "=", 
      RowBox[{
       RowBox[{"fs", " ", "f0p"}], " ", "-", " ", 
       RowBox[{"fsp", " ", "f0"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Wgsf0", "=", 
      RowBox[{
       RowBox[{"gs", " ", "f0p"}], " ", "-", " ", 
       RowBox[{"gsp", " ", "f0"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Wfsg0", "=", 
      RowBox[{
       RowBox[{"fs", " ", "g0p"}], "-", 
       RowBox[{"fsp", " ", "g0"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Wgsg0", "=", 
      RowBox[{
       RowBox[{"gs", " ", "g0p"}], "-", 
       RowBox[{"gsp", " ", "g0"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"tan\[Eta]", "=", 
      FractionBox["Wfsf0", "Wgsf0"]}], ";", "\[IndentingNewLine]", 
     RowBox[{"G", "=", 
      RowBox[{
       RowBox[{"-", 
        FractionBox[
         RowBox[{
          RowBox[{"Wfsg0", "*", "Wfsf0"}], "+", 
          RowBox[{"Wgsg0", "*", "Wgsf0"}]}], 
         RowBox[{
          SuperscriptBox["Wfsf0", "2"], "+", 
          SuperscriptBox["Wgsf0", "2"]}]]}], "/.", 
       RowBox[{"r", "\[Rule]", "rf"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{"G", " ", "=", 
        RowBox[{
         RowBox[{"-", 
          FractionBox[
           RowBox[{
            RowBox[{"(", 
             RowBox[{
              RowBox[{"g0", " ", "gsp"}], "-", 
              RowBox[{"g0p", " ", "gs"}]}], ")"}], "+", 
            RowBox[{"tan\[Eta]", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"g0", " ", "fsp"}], "-", 
               RowBox[{"g0p", " ", "fs"}]}], ")"}]}]}], 
           RowBox[{
            RowBox[{"(", 
             RowBox[{
              RowBox[{"f0", " ", "gsp"}], " ", "-", " ", 
              RowBox[{"f0p", " ", "gs"}]}], ")"}], "+", 
            RowBox[{"tan\[Eta]", " ", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"f0", " ", "fsp"}], " ", "-", " ", 
               RowBox[{"f0p", " ", "fs"}]}], ")"}]}]}]]}], "/.", 
         RowBox[{"r", "\[Rule]", "rf"}]}]}], ";"}], "*)"}], 
     "\[IndentingNewLine]", 
     RowBox[{"Return", "[", "G", "]"}]}]}], "\[IndentingNewLine]", 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.801399995682507*^9, 3.801400029161869*^9}, {
  3.801400080268821*^9, 3.801400080581738*^9}, {3.8014008501944103`*^9, 

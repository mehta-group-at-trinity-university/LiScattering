7f63496dfc8d"],

Cell[CellGroupData[{

Cell[TextData[{
 "Frame Transformation Method for Calculating ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["K", "sr"], TraditionalForm]],ExpressionUUID->
  "66ada961-eaf4-4a8c-8ae9-f50f8acdbd21"]
}], "Subsection",
 CellChangeTimes->{{3.8011827265697117`*^9, 
  3.80118273867739*^9}},ExpressionUUID->"48ad8721-33b6-4ef6-8b63-\

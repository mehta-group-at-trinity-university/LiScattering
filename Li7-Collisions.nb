Cell[BoxData[{
 RowBox[{
  RowBox[{"CalCKsr", "[", 
   RowBox[{
   "\[CapitalEpsilon]_", ",", "r0_", ",", "l_", ",", "rx_", ",", "rf_", ",", 
    "nr_", ",", "r_", ",", "\[Phi]_", ",", "rmin_", ",", "rmax_", ",", 
    "\[Mu]_", ",", "U_", ",", "C6_", ",", "C8_", ",", "C10_"}], "]"}], ":=", 
  " ", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "Y", ",", "kin", ",", "f0", ",", "g0", ",", "f0p", ",", "g0p", ",", 
      "\[Chi]m", ",", "\[Chi]mp", ",", "Ksr", ",", "\[Alpha]fun", ",", 
      "PhaseIntfun"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"Y", "=", 
      RowBox[{"CalcY", "[", 
       RowBox[{
       "\[CapitalEpsilon]", ",", "l", ",", "rmin", ",", "rmax", ",", "\[Mu]", 
        ",", "r0", ",", "U", ",", "r"}], "]"}]}], ";", "\[IndentingNewLine]", 
     
     RowBox[{
      RowBox[{"{", 
       RowBox[{"\[Alpha]fun", ",", "PhaseIntfun"}], "}"}], " ", "=", " ", 
      RowBox[{"CalcAlphaPhaseIntFun2", "[", 
       RowBox[{
       "\[CapitalEpsilon]", ",", "l", ",", "rx", ",", "rf", ",", "r", ",", 
        "nr", ",", "\[Mu]", ",", "C6", ",", "C8", ",", "C10"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "f0", ",", "g0", ",", "f0p", ",", "g0p", ",", "\[Chi]m", ",", 
        "\[Chi]mp"}], "}"}], " ", "=", " ", 
      RowBox[{"basepairs", "[", 
       RowBox[{
       "l", ",", "\[Phi]", ",", "\[Alpha]fun", ",", "PhaseIntfun", ",", 
        "r0"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Ksr", " ", "=", " ", 
      FractionBox[
       RowBox[{
        RowBox[{"Y", " ", "f0"}], " ", "-", "f0p"}], 
       RowBox[{
        RowBox[{"Y", " ", "g0"}], " ", "-", "g0p"}]]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Return", "[", "Ksr", "]"}]}]}], "\[IndentingNewLine]", 
   "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"CalcK", "[", 
   RowBox[{
   "\[CapitalEpsilon]_", ",", "r0_", ",", "l_", ",", "rx_", ",", "rf_", ",", 
    "nr_", ",", "r_", ",", "\[Phi]_", ",", "rmin_", ",", "rmax_", ",", 
    "\[Mu]_", ",", "U_", ",", "C6_", ",", "C8_", ",", "C10_"}], "]"}], ":=", 
  " ", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "f0", ",", "g0", ",", "f0p", ",", "g0p", ",", "\[Chi]m", ",", "\[Chi]mp",
       ",", "Ksr", ",", "\[Alpha]fun", ",", "PhaseIntfun", ",", "K", ",", "k",
       ",", "F", ",", "dF", ",", "G", ",", "dG"}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
      RowBox[{"{", 
       RowBox[{"\[Alpha]fun", ",", "PhaseIntfun"}], "}"}], " ", "=", " ", 
      RowBox[{"CalcAlphaPhaseIntFun2", "[", 
       RowBox[{
       "\[CapitalEpsilon]", ",", "l", ",", "rx", ",", "rf", ",", "r", ",", 
        "nr", ",", "\[Mu]", ",", "C6", ",", "C8", ",", "C10"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "f0", ",", "g0", ",", "f0p", ",", "g0p", ",", "\[Chi]m", ",", 
        "\[Chi]mp"}], "}"}], " ", "=", " ", 
      RowBox[{"basepairs", "[", 

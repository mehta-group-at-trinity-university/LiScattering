Cell[TextData[{
 "In this section, we define the full potential governing the interaction \
between two ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["", "7"], "Li"}], TraditionalForm]],ExpressionUUID->
  "ab7bcd6e-1eeb-4db3-b455-4d1c33ecb9aa"],
 " atoms. The full Hamiltonian for a ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["Li", "2"], TraditionalForm]],ExpressionUUID->
  "33845498-6453-4346-9954-131b349f35b9"],
 "collision is"
}], "Text",
 CellChangeTimes->{{3.801177988655484*^9, 3.8011780258116407`*^9}, {
  3.801179603747716*^9, 
  3.801179716814514*^9}},ExpressionUUID->"ace079bb-1d5f-4416-82c1-\
6d9aa7c3e4dc"],

Cell[BoxData[
 FormBox[
  RowBox[{"H", " ", "=", " ", 
   RowBox[{
    RowBox[{
     FractionBox[
      RowBox[{"-", 
       SuperscriptBox["\[HBar]", "2"]}], 
      RowBox[{"2", " ", "\[Mu]"}]], " ", 
     FractionBox[
      SuperscriptBox["d", "2"], 
      RowBox[{"d", " ", 
       SuperscriptBox["r", "2"]}]]}], " ", "+", " ", 
    RowBox[{
     SubscriptBox["P", "0"], 
     RowBox[{
      SubscriptBox["V", "0"], "(", "r", ")"}]}], " ", "+", " ", 
    RowBox[{
     SubscriptBox["P", "1"], 
     RowBox[{
      SubscriptBox["V", "1"], "(", "r", ")"}]}], " ", "+", 
    FractionBox[
     RowBox[{
      RowBox[{"l", "(", 
       RowBox[{"l", "+", "1"}], ")"}], 
      SuperscriptBox["\[HBar]", "2"]}], 
     RowBox[{"2", " ", "\[Mu]", " ", 
      SuperscriptBox["r", "2"]}]], "+", " ", 
    RowBox[{"\[Sum]", 
     RowBox[{
      SubscriptBox["A", "i"], "(", 
      RowBox[{
       SubscriptBox["s", "i"], "\[CenterDot]", " ", 
       SubscriptBox["i", "i"]}], ")"}]}], " ", "+", " ", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        SuperscriptBox[
         SubscriptBox["g", "s"], 
         RowBox[{"(", "i", ")"}]], " ", 
        SubscriptBox["\[Mu]", "B"], 
        SuperscriptBox[
         SubscriptBox["s", "z"], 
         RowBox[{"(", "i", ")"}]]}], "+", " ", 
       RowBox[{
        SuperscriptBox[
         SubscriptBox["g", "i"], 
         RowBox[{"(", "i", ")"}]], 
        SubscriptBox["\[Mu]", "N"], 
        SuperscriptBox[
         SubscriptBox["i", "z"], 
         RowBox[{"(", "i", ")"}]]}]}], ")"}], "B"}]}]}], 
  TraditionalForm]], "EquationNumbered",
 CellChangeTimes->{{3.801177988655484*^9, 3.8011780258116407`*^9}, {
  3.801179603747716*^9, 
  3.801179729684638*^9}},ExpressionUUID->"253e65b6-ff44-40c2-a7ae-\
6d448572592a"],

Cell[TextData[{
 "here ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["P", "0"], TraditionalForm]],ExpressionUUID->
  "83a1b5e3-07d3-4cea-a62e-6c18711145e2"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["P", "1"], TraditionalForm]],ExpressionUUID->
  "9bca70b0-2f3e-4faf-ad3a-c36a42302551"],
 " are the singlet and triplet projection operators, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["V", "0"], "(", "r", ")"}], TraditionalForm]],ExpressionUUID->
  "78834cd1-2348-4139-93d9-1178a5603dbc"],
 " is the potential for the ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["X", "1"], 
    SubscriptBox[
     SuperscriptBox["\[CapitalSigma]", "+"], "g"]}], TraditionalForm]],
  ExpressionUUID->"8c8a5207-96aa-45be-96ea-9efc99db7f60"],
 " state, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["V", "1"], "(", "r", ")"}], TraditionalForm]],ExpressionUUID->
  "52e672ed-f59d-45a7-a36f-e9cc2197d9bb"],
 " is the potential for the ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["a", "3"], 
    SubscriptBox[
     SuperscriptBox["\[CapitalSigma]", "+"], "u"]}], TraditionalForm]],
  ExpressionUUID->"d08a5584-e566-4ea2-88db-f804a3236d49"],
 " state, ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Mu]", "B"], TraditionalForm]],ExpressionUUID->
  "1bea50f4-95a2-4dd0-a1bd-5bbe690b867a"],
 " is the Bohr magneton, ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Mu]", "N"], TraditionalForm]],ExpressionUUID->
  "32d8ae49-c3bc-49c5-a138-c91540776f98"],
 " is the nuclear magneton, ",
 Cell[BoxData[
  FormBox["B", TraditionalForm]],ExpressionUUID->
  "2a5ef92c-363c-499b-8450-6c019617ed42"],
 " is the magnitude of an external magnetic field, applied along the ",
 Cell[BoxData[
  FormBox["z", TraditionalForm]],ExpressionUUID->
  "51fde146-0848-40fd-a955-55030d450147"],
 "-axis, ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["g", "s"], TraditionalForm]],ExpressionUUID->
  "5ba0ec38-70a7-4ee9-86cb-cdbe92cafe8b"],
 " is the electronic gyromagnetic ratio, ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["g", "i"], TraditionalForm]],ExpressionUUID->
  "350493fd-52e7-4113-893d-9cea4fb2e176"],
 " is the nuclear gyromagnetic ratio, ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "806b962a-7b24-482a-982b-2979d40140b1"],
 " is the hyperfine constant, ",
 Cell[BoxData[
  FormBox["s", TraditionalForm]],ExpressionUUID->
  "93e24667-e340-4a0b-9e6e-53c4de721b01"],
 " is the electronic spin, ",
 Cell[BoxData[
  FormBox["i", TraditionalForm]],ExpressionUUID->
  "9a1923a1-952a-44c0-8f22-be01bd0c3a1c"],
 " is the nuclear spin, ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["s", "z"], TraditionalForm]],ExpressionUUID->
  "d104b4d1-8e05-4c46-95fc-68314916a8f7"],
 " is the component of electronic spin along the ",
 Cell[BoxData[
  FormBox["z", TraditionalForm]],ExpressionUUID->
  "2191ba95-77e5-4fd0-b0e3-1bfb1b64d7fb"],
 "-axis, ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["i", "z"], TraditionalForm]],ExpressionUUID->
  "bb105797-5940-4338-8fad-6ecf027dd000"],
 " is the component of the nuclear spin along the ",
 Cell[BoxData[
  FormBox["z", TraditionalForm]],ExpressionUUID->
  "d458c808-7f10-46ff-9b39-eb46a41bd746"],
 "-axis, and the sum is over the two atoms.  "
}], "Text",
 CellChangeTimes->{{3.801177988655484*^9, 3.8011780258116407`*^9}, {
  3.801179603747716*^9, 
  3.8011797689483967`*^9}},ExpressionUUID->"29651f92-1f2b-4b39-bbf1-\
e6994eb2b2f5"],


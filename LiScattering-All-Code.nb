      SuperscriptBox["\[HBar]", "2"]}], 
     RowBox[{"2", " ", "\[Mu]", " ", 
      SuperscriptBox["r", "2"]}]], "+", " ", 
    RowBox[{"\[Sum]", 
     RowBox[{
      SubscriptBox["A", "i"], "(", 
      RowBox[{
       SubscriptBox["s", "i"], "\[CenterDot]", " ", 
       SubscriptBox["i", "i"]}], ")"}]}], " ", "+", " ", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        SuperscriptBox[
         SubscriptBox["g", "s"], 
         RowBox[{"(", "i", ")"}]], " ", 
        SubscriptBox["\[Mu]", "B"], 
        SuperscriptBox[
         SubscriptBox["s", "z"], 
         RowBox[{"(", "i", ")"}]]}], "+", " ", 
       RowBox[{
        SuperscriptBox[
         SubscriptBox["g", "i"], 
         RowBox[{"(", "i", ")"}]], 
        SubscriptBox["\[Mu]", "N"], 

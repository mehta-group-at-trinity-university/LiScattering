Cell[BoxData[{
 RowBox[{
  RowBox[{"TripletMLRHBdat", " ", "=", " ", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"RGrid", "[", 
        RowBox[{"[", "i", "]"}], "]"}], ",", 
       RowBox[{"invcminHartree", "*", 
        RowBox[{"TripletMLR", "[", 
         RowBox[{
          RowBox[{"RGrid", "[", 

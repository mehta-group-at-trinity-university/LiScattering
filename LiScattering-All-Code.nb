Cell[CellGroupData[{

Cell["\<\
Import the data from the full coupled-channels calculation using Johnson\
\[CloseCurlyQuote]s log-derivative method in FORTRAN\
\>", "Subsection",
 CellChangeTimes->{{3.800028717634781*^9, 
  3.800028769181364*^9}},ExpressionUUID->"25578721-f1a3-415b-b7a3-\
5f6cc0d450af"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"Li7FRData", "=", 
   RowBox[{"Import", "[", 
    RowBox[{
    "\"\</Users/niravmehta/Documents/GitHub/LiScattering/Li7FR.dat\>\"", ",", 
     " ", "\"\<Data\>\""}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"p0", "=", 
  RowBox[{"ListPlot", "[", 
   RowBox[{"Li7FRData", ",", 
    RowBox[{"Joined", "\[Rule]", "True"}], ",", 
    RowBox[{"PlotMarkers", "\[Rule]", "None"}], ",", 
    RowBox[{"Frame", "\[Rule]", "True"}], ",", 
    RowBox[{"PlotRange", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"-", "100"}], ",", "100"}], "}"}]}], ",", 
    RowBox[{"FrameLabel", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{
      "\"\<B [G]\>\"", ",", 
       "\"\<\!\(\*StyleBox[\"a\",FontSlant->\"Italic\"]\) \
[\!\(\*SubscriptBox[\(a\), \(0\)]\)]\>\""}], "}"}]}], ",", 
    RowBox[{"LabelStyle", "\[Rule]", "Medium"}], ",", 
    RowBox[{"GridLines", "\[Rule]", "Automatic"}], ",", 
    RowBox[{"GridLinesStyle", "\[Rule]", "Thin"}]}], 
   "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"p1", "=", 
  RowBox[{"ListLogPlot", "[", 
   RowBox[{"Li7FRData", ",", 
    RowBox[{"Joined", "\[Rule]", "True"}], ",", 
    RowBox[{"PlotMarkers", "\[Rule]", "None"}], ",", 
    RowBox[{"Frame", "\[Rule]", "True"}], 
    RowBox[{"(*", 
     RowBox[{"PlotRange", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"540", ",", "750"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"0", ",", "3000"}], "}"}]}], "}"}]}], "*)"}], ",", 
    RowBox[{"FrameLabel", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{
      "\"\<B [G]\>\"", ",", 
       "\"\<\!\(\*StyleBox[\"a\",FontSlant->\"Italic\"]\) \
[\!\(\*SubscriptBox[\(a\), \(0\)]\)]\>\""}], "}"}]}], ",", 
    RowBox[{"LabelStyle", "\[Rule]", "Medium"}], ",", 
    RowBox[{"GridLines", "\[Rule]", "Automatic"}], ",", 

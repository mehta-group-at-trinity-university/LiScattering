Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "This", " ", "next", " ", "bit", " ", "of", " ", "code", " ", "finds", " ",
     "the", " ", "constant", " ", "phases", " ", 
    SubscriptBox["\[Phi]", "i"], " ", "that", " ", "\"\<standardize\>\"", " ",
     "the", " ", "MQDT", 
    "\"\<.  \nThey ensure that the reference functions maintain maximal \
linear independence under the centrifugal barrier\>"}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{

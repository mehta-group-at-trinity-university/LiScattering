            RowBox[{"rf", "-", "rx"}], ")"}]}]}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", "1", ",", "nr"}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"PhaseIntTable", " ", "=", " ", 
       RowBox[{"Flatten", "[", 

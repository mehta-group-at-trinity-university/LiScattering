Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    RowBox[{
     TemplateBox[{
       RowBox[{"{", 
         RowBox[{
           RowBox[{"\[Alpha]", "'"}], 
           RowBox[{"\[Beta]", "'"}]}], "}"}]},
      "Bra"], 
     SuperscriptBox[
      SubscriptBox["H", "1"], "HZ"]}], "+", 
    RowBox[{
     SuperscriptBox[
      SubscriptBox["H", "2"], "HZ"], 
     TemplateBox[{
       RowBox[{"{", "\[Alpha]\[Beta]", "}"}]},
      "Ket"]}]}], "=", 
   RowBox[{
    FractionBox["1", 
     SqrtBox[
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "+", 
         SubscriptBox["\[Delta]", "\[Alpha]\[Beta]"]}], ")"}], 
       RowBox[{"(", 
        RowBox[{"1", "+", 
         SubscriptBox["\[Delta]", 
          RowBox[{
           RowBox[{"\[Alpha]", "'"}], 
           RowBox[{"\[Beta]", "'"}]}]]}], ")"}]}]]], "[", 
    RowBox[{
     RowBox[{
      TemplateBox[{
        RowBox[{"\[Alpha]", "'"}]},
       "Bra"], 
      SuperscriptBox["H", "HZ"], 
      TemplateBox[{"\[Alpha]"},
       "Ket"], 
      SubscriptBox["\[Delta]", 
       RowBox[{"\[Beta]\[Beta]", "'"}]]}], "+", 
     RowBox[{
      RowBox[{
       RowBox[{
        TemplateBox[{
          RowBox[{"\[Beta]", "'"}]},
         "Bra"], 
        SuperscriptBox["H", "HZ"], 
        TemplateBox[{"\[LineSeparator]"},
         "Ket"], 
        SubscriptBox["\[Delta]", 
         RowBox[{"\[Alpha]\[Alpha]", "'"}]]}], "\[PlusMinus]", 
       RowBox[{
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{"-", "1"}], ")"}], "l"], 
        TemplateBox[{
          RowBox[{"\[Alpha]", "'"}]},
         "Bra"], 
        SuperscriptBox["H", "HZ"], 
        TemplateBox[{"\[Beta]"},
         "Ket"], 
        SubscriptBox["\[Delta]", 
         RowBox[{"\[Alpha]\[Beta]", "'"}]]}]}], "\[PlusMinus]", 
      RowBox[{
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"-", "1"}], ")"}], "l"], 
       TemplateBox[{
         RowBox[{"\[Beta]", "'"}]},
        "Bra"], 
       SuperscriptBox["H", "HZ"], 
       TemplateBox[{"\[Alpha]"},
        "Ket"], 
       SubscriptBox["\[Delta]", 
        RowBox[{"\[Beta]\[Alpha]", "'"}]]}]}]}], "]"}]}], 

       "PhaseIntTable", ",", "rp", ",", "PhaseIntFun", ",", "\[Alpha]fun", 
       ",", "\[Alpha]"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"k", "=", 
       RowBox[{"Sqrt", "[", 
        RowBox[{"2", " ", "\[Mu]", " ", 
         RowBox[{"(", 
          RowBox[{"\[CapitalEpsilon]", "-", 
           RowBox[{"V", "[", "r", "]"}]}], ")"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"BC1", " ", "=", " ", 
       RowBox[{
        FractionBox["1", 
         RowBox[{"Sqrt", "[", 
          SuperscriptBox["k", 
           RowBox[{"1", "/", "2"}]], "]"}]], "/.", 
        RowBox[{"r", "\[Rule]", "rx"}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"BC2", " ", "=", " ", 

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"Rmax", "=", "300"}], ";"}], " ", 
  RowBox[{"(*", "bohr", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Rmin", "=", "2.0"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"NR", " ", "=", "300"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"dR", "=", 
   FractionBox[
    RowBox[{"(", 
     RowBox[{"Rmax", "-", "Rmin"}], ")"}], 
    RowBox[{"(", 
     RowBox[{"NR", "-", "1"}], ")"}]]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"RGrid", " ", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"Rmin", "+", 
      RowBox[{
       SuperscriptBox[
        RowBox[{"(", 
         FractionBox[
          RowBox[{"(", 
           RowBox[{"iR", "-", "1"}], ")"}], 
          RowBox[{"(", 
           RowBox[{"NR", "-", "1"}], ")"}]], ")"}], "4"], 
       RowBox[{"(", 
        RowBox[{"Rmax", "-", "Rmin"}], ")"}]}]}], ",", 
     RowBox[{"{", 
      RowBox[{"iR", ",", "1", ",", "NR"}], "}"}]}], "]"}]}], ";", 
  RowBox[{"Length", "[", "RGrid", "]"}]}]}], "Input",

Cell[BoxData[{
 RowBox[{
  RowBox[{"CalcCotanDelta", "[", 
   RowBox[{
   "\[Mu]_", ",", "\[CapitalEpsilon]test_", ",", "rmin_", ",", "rmax_"}], 
   "]"}], ":=", "\[IndentingNewLine]", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "CotanDelta", ",", "sol", ",", "k", ",", "u1", ",", "u2", ",", "r1", ",",
       "r2"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"r1", "=", 
      RowBox[{"0.95", " ", "rmax"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"r2", "=", 
      RowBox[{"0.99", "rmax"}]}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"k", "=", 
      SqrtBox[
       RowBox[{"2", " ", "\[Mu]", " ", "\[CapitalEpsilon]test"}]]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"sol", "=", 
      RowBox[{"NDSolve", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{
             FractionBox[
              RowBox[{"-", "1"}], 
              RowBox[{"2", "\[Mu]"}]], 
             RowBox[{
              RowBox[{"u", "''"}], "[", "r", "]"}]}], "+", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{
               RowBox[{"Vadiabatic", "[", "r", "]"}], "-", 
               RowBox[{"Vadiabatic", "[", "rmax", "]"}]}], ")"}], 
             RowBox[{"u", "[", "r", "]"}]}]}], "\[Equal]", 
           RowBox[{"\[CapitalEpsilon]test", " ", 
            RowBox[{"u", "[", "r", "]"}]}]}], ",", 
          RowBox[{
           RowBox[{"u", "[", "rmin", "]"}], "\[Equal]", "0"}], ",", 
          RowBox[{
           RowBox[{
            RowBox[{"u", "'"}], "[", "rmin", "]"}], "\[Equal]", 
           SuperscriptBox["10", 
            RowBox[{"-", "10"}]]}]}], "}"}], ",", "u", ",", 
        RowBox[{"{", 
         RowBox[{"r", ",", "rmin", ",", "rmax"}], "}"}], ",", 
        RowBox[{"AccuracyGoal", "\[Rule]", "30"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"u1", "=", 
      RowBox[{
       RowBox[{"u", "[", "r1", "]"}], "/.", 
       RowBox[{"sol", "[", 
        RowBox[{"[", "1", "]"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"u2", "=", 
      RowBox[{
       RowBox[{"u", "[", "r2", "]"}], "/.", 
       RowBox[{"sol", "[", 
        RowBox[{"[", "1", "]"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"CotanDelta", "=", 
      FractionBox[
       RowBox[{
        RowBox[{
         RowBox[{"-", "u2"}], " ", 
         RowBox[{"Cos", "[", 
          RowBox[{"k", " ", "r1"}], "]"}]}], "+", 
        RowBox[{"u1", " ", 
         RowBox[{"Cos", "[", 
          RowBox[{"k", " ", "r2"}], "]"}]}]}], 
       RowBox[{
        RowBox[{"u2", " ", 
         RowBox[{"Sin", "[", 
          RowBox[{"k", " ", "r1"}], "]"}]}], "-", 
        RowBox[{"u1", " ", 
         RowBox[{"Sin", "[", 
          RowBox[{"k", " ", "r2"}], "]"}]}]}]]}], ";", "\[IndentingNewLine]", 
     
     RowBox[{"Return", "[", "CotanDelta", "]"}]}]}], "\[IndentingNewLine]", 
   "]"}]}], "\n", 
 RowBox[{
  RowBox[{"CalcERE", "[", 
   RowBox[{
   "\[Mu]_", ",", "rmin_", ",", "rmax_", ",", "\[CapitalEpsilon]min_", ",", 
    "\[CapitalEpsilon]max_"}], "]"}], ":=", "\[IndentingNewLine]", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "vlocal", ",", "EREData", ",", "ascat", ",", "reff", ",", "A", ",", "B", 
      ",", "fitpars", ",", "dE", ",", "ksqr"}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"dE", "=", 
      FractionBox[
       RowBox[{"(", 
        RowBox[{"\[CapitalEpsilon]max", "-", "\[CapitalEpsilon]min"}], ")"}], 
       "10"]}], ";", "\[IndentingNewLine]", 
     RowBox[{"EREData", "=", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"2", "\[Mu]", " ", "\[CapitalEpsilon]"}], ",", 
          RowBox[{
           SqrtBox[
            RowBox[{"2", "\[Mu]", " ", "\[CapitalEpsilon]"}]], 
           RowBox[{"CalcCotanDelta", "[", 
            RowBox[{
            "\[Mu]", ",", "\[CapitalEpsilon]", ",", "rmin", ",", "rmax"}], 
            "]"}]}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{
         "\[CapitalEpsilon]", ",", "\[CapitalEpsilon]min", ",", 
          "\[CapitalEpsilon]max", ",", "dE"}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"fitpars", "=", 
      RowBox[{"FindFit", "[", 
       RowBox[{"EREData", ",", 
        RowBox[{"A", "+", 
         RowBox[{"B", " ", "ksqr"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"A", ",", "B"}], "}"}], ",", "ksqr"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"ascat", "=", 
      RowBox[{
       FractionBox[
        RowBox[{"-", "1"}], "A"], "/.", "fitpars"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"reff", "=", 
      RowBox[{
       RowBox[{"2", "B"}], "/.", "fitpars"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Return", "[", 
      RowBox[{"{", 
       RowBox[{"ascat", ",", "reff", ",", "EREData"}], "}"}], "]"}]}]}], 

Cell["I. Define zero-energy solution and Riccati functions", "Text",
 CellChangeTimes->{{3.799417382596978*^9, 3.799417396479372*^9}, {
   3.799417449225484*^9, 3.799417465864058*^9}, 3.799417511757659*^9, {
   3.7994175426120777`*^9, 3.79941760391451*^9}},
 TextAlignment->Left,ExpressionUUID->"a8a036f3-51f7-4e36-8a05-60ee618cb1fa"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"Clear", "[", 
   RowBox[{"l", ",", "r", ",", "rp"}], "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"\[Chi]minus", "[", 
    RowBox[{"r_", ",", "l_"}], "]"}], "=", " ", 
   RowBox[{
    RowBox[{"Sqrt", "[", "r", "]"}], " ", 
    RowBox[{"BesselJ", "[", 
     RowBox[{
      RowBox[{
       FractionBox["1", "4"], 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"2", "l"}], "+", "1"}], ")"}]}], ",", 
      FractionBox["1", 
       RowBox[{"2", " ", 
        SuperscriptBox["r", "2"]}]]}], "]"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"\[Chi]mprime", "[", 
    RowBox[{"r_", ",", "l_"}], "]"}], "=", " ", 
   RowBox[{
    RowBox[{"D", "[", 
     RowBox[{
      RowBox[{"\[Chi]minus", "[", 
       RowBox[{"rp", ",", "l"}], "]"}], ",", "rp"}], "]"}], "/.", 
    RowBox[{"rp", "\[Rule]", "r"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"f", "[", 
    RowBox[{"l_", ",", "k_", ",", "r_"}], "]"}], "=", 
   RowBox[{"(*", 
    SqrtBox[
     FractionBox[
      RowBox[{"2", " ", "\[Mu]", " ", "k"}], 
      RowBox[{"\[Pi]", " "}]]], "*)"}], 
   RowBox[{"r", " ", 
    RowBox[{"SphericalBesselJ", "[", 
     RowBox[{"l", ",", 
      RowBox[{"k", " ", "r"}]}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"g", "[", 
    RowBox[{"l_", ",", "k_", ",", "r_"}], "]"}], "=", 
   RowBox[{"(*", 
    SqrtBox[
     FractionBox[
      RowBox[{"2", " ", "\[Mu]", " ", "k"}], 
      RowBox[{"\[Pi]", " "}]]], "*)"}], 
   RowBox[{"r", " ", 
    RowBox[{"SphericalBesselY", "[", 
     RowBox[{"l", ",", 
      RowBox[{"k", " ", "r"}]}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"dfdr", "[", 
     RowBox[{"l_", ",", "k_", ",", "r_"}], "]"}], "=", 
    RowBox[{
     RowBox[{"Simplify", "[", 
      RowBox[{"D", "[", 
       RowBox[{
        RowBox[{"f", "[", 
         RowBox[{"l", ",", "k", ",", "rp"}], "]"}], ",", "rp"}], "]"}], "]"}],
      "/.", 
     RowBox[{"rp", "\[Rule]", "r"}]}]}], ";"}], " "}], "\[IndentingNewLine]", 

 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"dgdr", "[", 
     RowBox[{"l_", ",", "k_", ",", "r_"}], "]"}], "=", 
    RowBox[{
     RowBox[{"Simplify", "[", 
      RowBox[{"D", "[", 
       RowBox[{
        RowBox[{"g", "[", 
         RowBox[{"l", ",", "k", ",", "rp"}], "]"}], ",", "rp"}], "]"}], "]"}],
      "/.", " ", 
     RowBox[{"rp", "\[Rule]", "r"}]}]}], ";"}], " "}]}], "Input",
 CellChangeTimes->{{3.799417382596978*^9, 3.799417396479372*^9}, {
   3.799417449225484*^9, 3.799417465864058*^9}, 3.799417511757659*^9, {
   3.7994175426120777`*^9, 3.799417649699533*^9}, {3.799417698455481*^9, 
   3.799417802308331*^9}, 3.799418257817822*^9, {3.799430894754375*^9, 
   3.7994309002747107`*^9}, {3.7994529285440083`*^9, 3.799452940152857*^9}, {
   3.800979655549033*^9, 3.800979696352375*^9}},
 TextAlignment->Left,
 CellLabel->"In[37]:=",ExpressionUUID->"f944c847-c708-41c5-8d05-217437d36b88"],

Cell["II. Define reference wave-function base pairs ", "Text",
 CellChangeTimes->{{3.799418286723205*^9, 3.799418332471654*^9}, {
  3.799436460942225*^9, 
  3.799436461564991*^9}},ExpressionUUID->"0651289f-b847-4cc9-92b0-\
4e50c74a3be7"],

Cell[BoxData[
 RowBox[{
  RowBox[{"basepairs", "[", 
   RowBox[{
   "l_", ",", "\[Phi]_", ",", "\[Alpha]_", ",", "phaseint_", ",", "r_"}], 
   "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "\[Alpha]p", ",", "rp", ",", "f0", ",", "g0", ",", "f0p", ",", "g0p", 
      ",", "\[Chi]m", ",", "\[Chi]mp"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"\[Alpha]p", "=", 
      RowBox[{"\[Alpha]", "'"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"g0", "=", 
      RowBox[{
       RowBox[{"-", 
        RowBox[{"\[Alpha]", "[", "r", "]"}]}], 
       RowBox[{"Cos", "[", 
        RowBox[{"\[Phi]", "+", 
         RowBox[{"phaseint", "[", "r", "]"}]}], "]"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"f0", "=", 
      RowBox[{
       RowBox[{"\[Alpha]", "[", "r", "]"}], 
       RowBox[{"Sin", "[", 
        RowBox[{"\[Phi]", "+", 
         RowBox[{"phaseint", "[", "r", "]"}]}], "]"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"f0p", "=", 
      RowBox[{
       RowBox[{
        FractionBox[
         RowBox[{"\[Alpha]p", "[", "r", "]"}], 
         RowBox[{"\[Alpha]", "[", "r", "]"}]], "f0"}], "-", 
       RowBox[{
        FractionBox["1", 
         SuperscriptBox[
          RowBox[{"\[Alpha]", "[", "r", "]"}], "2"]], "g0"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"g0p", "=", 
      RowBox[{
       RowBox[{
        FractionBox[
         RowBox[{"\[Alpha]p", "[", "r", "]"}], 
         RowBox[{"\[Alpha]", "[", "r", "]"}]], "g0"}], "+", 
       RowBox[{
        FractionBox["1", 
         SuperscriptBox[
          RowBox[{"\[Alpha]", "[", "r", "]"}], "2"]], "f0"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"\[Chi]m", "=", 
      RowBox[{"\[Chi]minus", "[", 
       RowBox[{"r", ",", "l"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"\[Chi]mp", "=", 
      RowBox[{"\[Chi]mprime", "[", 
       RowBox[{"r", ",", "l"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{
      "f0", ",", "g0", ",", "f0p", ",", "g0p", ",", "\[Chi]m", ",", 
       "\[Chi]mp"}], "}"}]}]}], "]"}]}]], "Input",
 CellChangeTimes->{3.7994183691576767`*^9},
 CellLabel->"In[44]:=",ExpressionUUID->"3652f59f-29f4-4e26-9449-11545ce77d5b"],

Cell[TextData[{
 "III. Calculate alpha and phase integral functions using the Milne method. \
These will then be used for constructing the reference wave functions ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["f", "o"], TraditionalForm]],ExpressionUUID->
  "277ea6db-2448-4692-9673-ecfe65469e08"],
 " and ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["g", "o"], TraditionalForm]],ExpressionUUID->
  "44674361-e968-4e8a-b313-38fdf50af8da"],
 " in the long range-region."
}], "Text",
 CellChangeTimes->{{3.799418391649331*^9, 3.799418420418486*^9}, {
  3.799418741731647*^9, 
  3.799418745452855*^9}},ExpressionUUID->"2c409b9c-2ca0-40ed-8891-\
5193ad789177"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"CalcAlphaPhaseIntFun", "[", 
    RowBox[{
    "\[CapitalEpsilon]_", ",", "l_", ",", "nr_", ",", "\[Mu]_", ",", "V_", 

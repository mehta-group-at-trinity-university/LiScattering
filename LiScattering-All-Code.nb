                RowBox[{"\[Alpha]", "[", "r", "]"}], "3"]]}], "\[Equal]", 
             "0"}], ",", 
            RowBox[{
             RowBox[{"\[Alpha]", "[", "rx", "]"}], "\[Equal]", 
             RowBox[{"BC1", "[", 
              RowBox[{
              "\[CapitalEpsilon]test", ",", "ltest", ",", "r", ",", "rx", ",",
                "\[Mu]"}], "]"}]}], ",", 
            RowBox[{
             RowBox[{
              RowBox[{"\[Alpha]", "'"}], "[", "rx", "]"}], "\[Equal]", 
             RowBox[{"BC2", "[", 
              RowBox[{
              "\[CapitalEpsilon]test", ",", "ltest", ",", "r", ",", "rx", ",",
                "\[Mu]"}], "]"}]}]}], "}"}], ",", "\[Alpha]", ",", 
          RowBox[{"{", 
           RowBox[{"r", ",", "rx", ",", "rf"}], "}"}]}], "]"}], ",", 
        RowBox[{"{", 

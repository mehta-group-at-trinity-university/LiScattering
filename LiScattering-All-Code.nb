    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"u", "=", 
      RowBox[{"NDSolveValue", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{
             FractionBox[
              RowBox[{"-", "1"}], 
              RowBox[{"2", " ", "\[Mu]"}]], 
             RowBox[{
              RowBox[{"u", "''"}], "[", "r", "]"}]}], "+", " ", 
            RowBox[{
             RowBox[{"V", "[", "r", "]"}], "*", 
             RowBox[{"u", "[", "r", "]"}]}]}], "\[Equal]", 
           RowBox[{"\[CapitalEpsilon]", " ", 
            RowBox[{"u", "[", "r", "]"}]}]}], ",", 
          RowBox[{
           RowBox[{"u", "[", "rmin", "]"}], "\[Equal]", "0"}], ",", 
          RowBox[{
           RowBox[{
            RowBox[{"u", "'"}], "[", "rmin", "]"}], "\[Equal]", 
           SuperscriptBox["10", 
            RowBox[{"-", "10"}]]}]}], "}"}], ",", "u", ",", 
        RowBox[{"{", 
         RowBox[{"r", ",", "rmin", ",", "rmax"}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"up", "[", "r_", "]"}], " ", "=", " ", 
      RowBox[{
       RowBox[{"D", "[", 
        RowBox[{
         RowBox[{"u", "[", "rp", "]"}], ",", "rp"}], "]"}], "/.", 
       RowBox[{"rp", "\[Rule]", "r"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Y", " ", "=", " ", 
      RowBox[{
       FractionBox[
        RowBox[{"up", "[", "r", "]"}], 
        RowBox[{"u", "[", "r", "]"}]], "/.", 
       RowBox[{"r", "\[Rule]", "rmax"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Return", "[", "Y", "]"}]}]}], "\[IndentingNewLine]", 

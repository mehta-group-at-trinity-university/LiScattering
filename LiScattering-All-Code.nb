Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"VR", "[", 
    RowBox[{"r_", ",", "B_"}], "]"}], ":=", 
   RowBox[{
    RowBox[{
     RowBox[{"AsymC", "[", "B", "]"}], ".", " ", 
     RowBox[{"HZsymLi7", "[", "B", "]"}], ".", 
     RowBox[{"Transpose", "[", 
      RowBox[{"AsymC", "[", "B", "]"}], "]"}]}], "+", 
    RowBox[{
     RowBox[{
      RowBox[{"AsymC", "[", "B", "]"}], ".", "SymTripletProjLi7MF2", ".", 
      RowBox[{"Transpose", "[", 
       RowBox[{"AsymC", "[", "B", "]"}], "]"}]}], "*", 
     RowBox[{"TripletHBMLR", "[", "r", "]"}]}], "+", 
    RowBox[{
     RowBox[{
      RowBox[{"AsymC", "[", "B", "]"}], ".", "SymSingletProjLi7MF2", ".", 
      RowBox[{"Transpose", "[", 
       RowBox[{"AsymC", "[", "B", "]"}], "]"}]}], "*", 
     RowBox[{"SingletHBMLR", "[", "r", "]"}]}]}]}], ";"}]], "Input",

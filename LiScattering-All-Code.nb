Cell[BoxData[
 RowBox[{
  RowBox[{"CalcCotGamma", "[", 
   RowBox[{
   "l_", ",", "rx_", ",", "rf_", ",", "\[Mu]_", ",", "r_", ",", "\[Epsilon]_",
     ",", "\[Phi]_", ",", "Vlr_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "nr", ",", "asol", ",", "phaseintfun", ",", "cot\[Gamma]", ",", "gbound",
       ",", "gboundp", ",", "\[Kappa]", ",", "f0", ",", "g0", ",", "f0p", ",",
       "g0p", ",", "\[Chi]m", ",", "\[Chi]mp"}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"\[Kappa]", "=", 
      SqrtBox[
       RowBox[{"Abs", "[", 
        RowBox[{"2", "\[Mu]", " ", "\[Epsilon]"}], "]"}]]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{
      "\[CapitalEpsilon]_", ",", "l_", ",", "nr_", ",", "\[Mu]_", ",", "V_", 
       ",", "rx_", ",", "rf_", ",", "r_"}], "*)"}], "\[IndentingNewLine]", 
     RowBox[{"nr", "=", "300"}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"asol", ",", "phaseintfun"}], "}"}], "=", " ", 
      RowBox[{"CalcAlphaPhaseIntFun", "[", 
       RowBox[{
       "\[Epsilon]", ",", "l", ",", "nr", ",", "\[Mu]", ",", "Vlr", ",", "rx",
         ",", "rf", ",", "r"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "f0", ",", "g0", ",", "f0p", ",", "g0p", ",", "\[Chi]m", ",", 
        "\[Chi]mp"}], "}"}], "=", 
      RowBox[{"basepairs", "[", 
       RowBox[{
       "l", ",", "\[Phi]", ",", "asol", ",", "phaseintfun", ",", "r"}], 
       "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{"gbound", "=", 
        RowBox[{
         RowBox[{
          SqrtBox[
           RowBox[{
            FractionBox["2", "\[Pi]"], "\[Kappa]", " ", "rp"}]], 
          RowBox[{"BesselK", "[", 
           RowBox[{
            RowBox[{"l", "+", 
             FractionBox["1", "2"]}], ",", 
            RowBox[{"\[Kappa]", " ", "rp"}]}], "]"}]}], "/.", 
         RowBox[{"rp", "\[Rule]", "rf"}]}]}], ";", " ", "\[IndentingNewLine]", 
       RowBox[{"gboundp", "=", 
        RowBox[{
         RowBox[{"-", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"\[Kappa]", " ", 
              RowBox[{"(", 
               RowBox[{
                RowBox[{"rp", " ", "\[Kappa]", " ", 
                 RowBox[{"BesselK", "[", 
                  RowBox[{
                   RowBox[{
                    RowBox[{"-", 
                    FractionBox["1", "2"]}], "+", "l"}], ",", 
                   RowBox[{"rp", " ", "\[Kappa]"}]}], "]"}]}], "-", 
                RowBox[{"BesselK", "[", 
                 RowBox[{
                  RowBox[{
                   FractionBox["1", "2"], "+", "l"}], ",", 
                  RowBox[{"rp", " ", "\[Kappa]"}]}], "]"}], "+", 
                RowBox[{"rp", " ", "\[Kappa]", " ", 
                 RowBox[{"BesselK", "[", 
                  RowBox[{
                   RowBox[{
                    FractionBox["3", "2"], "+", "l"}], ",", 
                   RowBox[{"rp", " ", "\[Kappa]"}]}], "]"}]}]}], ")"}]}], 
             ")"}], "/", 
            RowBox[{"(", 
             RowBox[{
              SqrtBox[
               RowBox[{"2", " ", "\[Pi]"}]], " ", 
              SqrtBox[
               RowBox[{"rp", " ", "\[Kappa]"}]]}], ")"}]}], ")"}]}], "/.", 
         RowBox[{"rp", "\[Rule]", "rf"}]}]}], ";"}], "*)"}], 
     "\[IndentingNewLine]", 
     RowBox[{"gbound", " ", "=", " ", 
      RowBox[{"Exp", "[", 
       RowBox[{
        RowBox[{"-", "\[Kappa]"}], " ", "r"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"gboundp", " ", "=", 
      RowBox[{
       RowBox[{"-", " ", "\[Kappa]"}], " ", 
       RowBox[{"Exp", "[", 
        RowBox[{
         RowBox[{"-", "\[Kappa]"}], " ", "r"}], "]"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"cot\[Gamma]", " ", "=", 
      RowBox[{
       FractionBox[
        RowBox[{
         RowBox[{
          RowBox[{"-", "gbound"}], " ", "f0p"}], " ", "-", " ", 
         RowBox[{"gboundp", " ", "f0"}]}], 
        RowBox[{
         RowBox[{"gbound", " ", "g0p"}], "-", 
         RowBox[{"gboundp", " ", "g0"}]}]], "/.", 
       RowBox[{"r", "\[Rule]", "rf"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Return", "[", "cot\[Gamma]", "]"}]}]}], "\[IndentingNewLine]", 
   "]"}]}]], "Input",
 CellChangeTimes->{
  3.800983090874914*^9, 3.8009831868130407`*^9, {3.800983372917831*^9, 
   3.800983472773649*^9}, {3.8009835513601847`*^9, 3.8009835536589537`*^9}},
